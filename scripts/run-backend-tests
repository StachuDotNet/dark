#!/usr/bin/env bash
. ./scripts/devcontainer/_assert-in-container "$0" "$@"

set -euo pipefail

trap ctrl_c INT

function ctrl_c() {
  killall -9 Tests
  exit 1
}

PUBLISHED=false
PUBLISHED_FLAG=

EXPECTO_ARGS=()

for i in "$@"
do
  case "${i}" in
    --published)
      PUBLISHED=true
      PUBLISHED_FLAG=$i
      ;;
    *) EXPECTO_ARGS+=("${i}");;
  esac
done

killall -9 Tests || true

if [[ "$PUBLISHED" == "true" ]]; then
  EXE=Build/out/Tests/Release/net10.0/publish/Tests
  LOCALEXEC=Build/out/LocalExec/Release/net10.0/publish/LocalExec
else
  EXE=Build/out/Tests/Debug/net10.0/Tests
  LOCALEXEC=Build/out/LocalExec/Debug/net10.0/LocalExec
fi

grey="\033[1;30m"
reset="\033[0m"

# Build the binaries this script runs, and ABORT on any compile error, BEFORE we touch the DB / run anything.
# Otherwise run-backend-tests just executes the pre-built ${EXE}/${LOCALEXEC} — so a failed rebuild silently
# falls back to the last good binary and reports "Success" on stale code (a compile error in a new test hid as
# a passing run). `set -euo pipefail` makes a non-zero build abort here. Published mode is built by a separate
# publish step, so there we only assert the artifacts exist rather than rebuild.
if [[ "$PUBLISHED" == "true" ]]; then
  for exe in "$EXE" "$LOCALEXEC"; do
    if [[ ! -x "backend/$exe" ]]; then
      echo "ERROR: published binary missing: backend/$exe — run the publish step first." >&2
      exit 1
    fi
  done
else
  echo -e "Building backend ${grey}(fail fast on compile errors)${reset}"
  ( cd backend \
      && DARK_CONFIG_TELEMETRY_EXPORTER=none dotnet build src/LocalExec/LocalExec.fsproj -c Debug --nologo -v q \
      && DARK_CONFIG_TELEMETRY_EXPORTER=none dotnet build tests/Tests/Tests.fsproj -c Debug --nologo -v q )
fi


LOGS="${DARK_CONFIG_RUNDIR}/logs"


# Delete the database file before running tests.
# WAL mode keeps `.db-wal` (uncommitted writes) and `.db-shm`
# (shared-memory index) alongside `.db`. Removing only `.db`
# leaves the WAL behind — the next run picks it up and behaves
# unpredictably (slow / corrupt).
export DARK_CONFIG_DB_NAME=test-data.db
DB_PATH="${DARK_CONFIG_RUNDIR}/${DARK_CONFIG_DB_NAME}"
echo -e "Deleting database file ${grey}(${DB_PATH})${reset}"
rm -f "$DB_PATH" "$DB_PATH-wal" "$DB_PATH-shm"

# Run the migrations before the other servers start
echo -e "Running migrations ${grey}($LOGS/test-migrations.log)${reset}"
cd backend && \
  DARK_CONFIG_TELEMETRY_EXPORTER=none \
  "${LOCALEXEC}" migrations run > "$LOGS/test-migrations.log" 2>&1
cd ..

if [[ "${DARK_CONFIG_PACKAGES_SOURCE:-disk}" == "seed" ]]; then
  # Seed mode: copy seed as test DB, Tests exe auto-grows on startup
  SEED_PATH="${DARK_CONFIG_RUNDIR}/seed.db"
  if [[ -f "$SEED_PATH" ]]; then
    echo "Copying seed.db as test database"
    cp "$SEED_PATH" "$DB_PATH"
  else
    echo "ERROR: No seed.db found at $SEED_PATH"
    echo "Run: ./scripts/run-cli export-seed /home/dark/app/rundir/seed.db"
    echo "Or:  ./scripts/fetch-seed"
    exit 1
  fi
else
  # Disk mode: reload packages from .dark files.
  #  Migrations already ran inline above
  if [[ -v CI ]]; then
    echo "Reloading packages"
    ./scripts/build/reload-packages $PUBLISHED_FLAG
  else
    echo "Reloading packages"
    ./scripts/build/reload-packages --test $PUBLISHED_FLAG
  fi
fi

JUNIT_FILE="${DARK_CONFIG_RUNDIR}/test_results/backend.xml"


COLOURS="256"
SPINNER=
if [[ -v CI ]]; then
  # Expecto needs `--colours 0` or the xml will be invalid
  # https://github.com/haf/expecto/issues/434
  COLOURS="0"
  SPINNER="--no-spinner"
fi

TEST_LOG="${LOGS}/fsharp-tests.log"
true > "${TEST_LOG}" # truncate

cd backend
echo -e "Logging to: ${grey}${TEST_LOG}${reset}"
DARK_CONFIG_TELEMETRY_EXPORTER=none \
"${EXE}" ${SPINNER} --colours "${COLOURS}" --junit-summary "${JUNIT_FILE}" "${EXPECTO_ARGS[@]}" 2>&1 | tee "${TEST_LOG}"
