val sonnet4 = "claude-sonnet-4-20250514"
val opus4 = "claude-opus-4-20250514"
val sonnet37 = "claude-3-7-sonnet-20250219"
val sonnet37Latest = "claude-3-7-sonnet-latest"
val sonnet35 = "claude-3-5-sonnet-20241022"
val sonnet35Latest = "claude-3-5-sonnet-latest"
val haiku35 = "claude-3-5-haiku-20241022"
val haiku35Latest = "claude-3-5-haiku-latest"
