module Darklang.Cli.Outliner.Tests

type TestResult =
  | Pass
  | Fail of message: String

type TestFunction = Unit -> TestResult

type TestSummary =
  { totalTests: Int
    passedTests: Int
    failedTests: Int
    failedTestNames: List<String> }


// --- Helpers ---

let makeEditor (outline: Outline) : OutlineEditor.State =
  OutlineEditor.fromOutline outline

let makeMainState (outline: Outline) : Main.State =
  let doc =
    Document
      { id = 1
        title = "Test Doc"
        outline = outline }
  let docs = [doc]
  let picker = ListPicker.make docs (fun d -> d.title)
  Main.State
    { documents = docs
      activeDocId = 1
      nextDocId = 2
      screen = Main.Screen.Editor (makeEditor outline) }

let assertEq (label: String) (actual: String) (expected: String) : TestResult =
  if actual == expected then
    TestResult.Pass
  else
    TestResult.Fail $"{label}: expected '{expected}', got '{actual}'"

let assertInt (label: String) (actual: Int) (expected: Int) : TestResult =
  if actual == expected then
    TestResult.Pass
  else
    TestResult.Fail $"{label}: expected {Stdlib.Int.toString expected}, got {Stdlib.Int.toString actual}"


// --- Outline tests ---

let testFlattenVisibleCountsAllNodes () : TestResult =
  let outline =
    buildOutline
      [(1, "A"); (2, "B"); (3, "C"); (4, "D")]
      [(1, [2; 3])]
      [1; 4]
      5
  let flat = flattenVisible outline
  assertInt "visible count" (Stdlib.List.length flat) 4

let testFlattenVisibleRespectsCollapse () : TestResult =
  let outline =
    buildOutline
      [(1, "A"); (2, "B"); (3, "C"); (4, "D")]
      [(1, [2; 3])]
      [1; 4]
      5
  let collapsed = setCollapsed outline 1 true
  let flat = flattenVisible collapsed
  assertInt "visible count" (Stdlib.List.length flat) 2

let testBuildOutline () : TestResult =
  let outline =
    buildOutline
      [(1, "A"); (2, "B"); (3, "C")]
      [(1, [2; 3])]
      [1]
      4
  let flat = flattenVisible outline
  if Stdlib.List.length flat == 3 then
    match Stdlib.List.head flat with
    | Some vn ->
      if vn.text == "A" && vn.hasChildren && vn.depth == 0 then
        TestResult.Pass
      else
        TestResult.Fail "First node should be A with children at depth 0"
    | None -> TestResult.Fail "No visible nodes"
  else
    TestResult.Fail $"Expected 3 visible, got {Stdlib.Int.toString (Stdlib.List.length flat)}"

let testFindParentId () : TestResult =
  let outline =
    buildOutline
      [(1, "Parent"); (2, "Child"); (3, "Root2")]
      [(1, [2])]
      [1; 3]
      4
  let childParent = findParentId outline 2
  let rootParent = findParentId outline 1
  match childParent with
  | Some pid ->
    if pid == 1 then
      match rootParent with
      | None -> TestResult.Pass
      | Some _ -> TestResult.Fail "Root node should have no parent"
    else
      TestResult.Fail $"Expected parent 1, got {Stdlib.Int.toString pid}"
  | None -> TestResult.Fail "Child should have a parent"


// --- OutlineEditor tests ---

let testInsertAfterAddsNode () : TestResult =
  let outline =
    buildOutline
      [(1, "First")]
      []
      [1]
      2
  let editor = makeEditor outline
  let newEditor = OutlineEditor.insertAfter editor
  let flat = flattenVisible newEditor.outline
  assertInt "visible count" (Stdlib.List.length flat) 2

let testInsertAfterEmptyTree () : TestResult =
  let outline = emptyOutline ()
  let editor = makeEditor outline
  let newEditor = OutlineEditor.insertAfter editor
  assertInt "root count" (Stdlib.List.length newEditor.outline.rootChildren) 1

let testDeleteEmptyNode () : TestResult =
  let outline =
    buildOutline
      [(1, ""); (2, "Keep")]
      []
      [1; 2]
      3
  let editor = makeEditor outline
  let newEditor = OutlineEditor.deleteNode editor
  assertInt "root count" (Stdlib.List.length newEditor.outline.rootChildren) 1

let testDeleteNonEmptyNodeDoesNothing () : TestResult =
  let outline =
    buildOutline
      [(1, "Has text")]
      []
      [1]
      2
  let editor = makeEditor outline
  let newEditor = OutlineEditor.deleteNode editor
  assertInt "root count" (Stdlib.List.length newEditor.outline.rootChildren) 1

let testToggleCollapse () : TestResult =
  let outline =
    buildOutline
      [(1, "Parent"); (2, "Child")]
      [(1, [2])]
      [1]
      3
  let editor = makeEditor outline
  let newEditor = OutlineEditor.toggleCollapse editor
  let s = getStructure newEditor.outline 1
  if s.collapsed then TestResult.Pass
  else TestResult.Fail "Expected node to be collapsed"

let testToggleCollapseLeafDoesNothing () : TestResult =
  let outline =
    buildOutline
      [(1, "Leaf")]
      []
      [1]
      2
  let editor = makeEditor outline
  let newEditor = OutlineEditor.toggleCollapse editor
  let s = getStructure newEditor.outline 1
  if s.collapsed then TestResult.Fail "Leaf should not be collapsible"
  else TestResult.Pass

let testIndentNode () : TestResult =
  let outline =
    buildOutline
      [(1, "First"); (2, "Second")]
      []
      [1; 2]
      3
  let editor = { (makeEditor outline) with cursor = 1 }
  let newEditor = OutlineEditor.indentNode editor
  let rootCount = Stdlib.List.length newEditor.outline.rootChildren
  if rootCount == 1 then
    let s = getStructure newEditor.outline 1
    assertInt "child count" (Stdlib.List.length s.children) 1
  else
    TestResult.Fail $"Expected 1 root after indent, got {Stdlib.Int.toString rootCount}"

let testOutdentNode () : TestResult =
  let outline =
    buildOutline
      [(1, "Parent"); (2, "Child")]
      [(1, [2])]
      [1]
      3
  let editor = { (makeEditor outline) with cursor = 1 }
  let newEditor = OutlineEditor.outdentNode editor
  assertInt "root count" (Stdlib.List.length newEditor.outline.rootChildren) 2

let testMoveNodeUp () : TestResult =
  let outline =
    buildOutline
      [(1, "First"); (2, "Second")]
      []
      [1; 2]
      3
  let editor = { (makeEditor outline) with cursor = 1 }
  let newEditor = OutlineEditor.moveNodeUp editor
  match Stdlib.List.head newEditor.outline.rootChildren with
  | Some firstId ->
    let text = getNodeText newEditor.outline firstId
    assertEq "first node" text "Second"
  | None -> TestResult.Fail "No root nodes"

let testMoveNodeDown () : TestResult =
  let outline =
    buildOutline
      [(1, "First"); (2, "Second")]
      []
      [1; 2]
      3
  let editor = makeEditor outline
  let newEditor = OutlineEditor.moveNodeDown editor
  match Stdlib.List.head newEditor.outline.rootChildren with
  | Some firstId ->
    let text = getNodeText newEditor.outline firstId
    assertEq "first node" text "Second"
  | None -> TestResult.Fail "No root nodes"

let testMoveCursorUpDown () : TestResult =
  let outline =
    buildOutline
      [(1, "A"); (2, "B"); (3, "C")]
      []
      [1; 2; 3]
      4
  let editor = makeEditor outline
  let down1 = OutlineEditor.moveCursorDown editor
  let down2 = OutlineEditor.moveCursorDown down1
  let up1 = OutlineEditor.moveCursorUp down2
  if down1.cursor == 1 && down2.cursor == 2 && up1.cursor == 1 then
    TestResult.Pass
  else
    TestResult.Fail $"Cursor movement: d1={Stdlib.Int.toString down1.cursor} d2={Stdlib.Int.toString down2.cursor} u1={Stdlib.Int.toString up1.cursor}"

let testMoveCursorBounds () : TestResult =
  let outline =
    buildOutline
      [(1, "Only")]
      []
      [1]
      2
  let editor = makeEditor outline
  let upFromZero = OutlineEditor.moveCursorUp editor
  let downFromMax = OutlineEditor.moveCursorDown editor
  if upFromZero.cursor == 0 && downFromMax.cursor == 0 then
    TestResult.Pass
  else
    TestResult.Fail "Cursor should not move past bounds"


// --- TextEditor tests ---

let testTextEditorInsert () : TestResult =
  let te = TextEditor.fromText "Hello"
  match TextEditor.handleKey te (Stdlib.Cli.Stdin.Key.Key.None) (Stdlib.Cli.Stdin.Modifiers.Modifiers { shift = false; ctrl = false; alt = false }) (Stdlib.Option.Option.Some "!") with
  | Editing newTe -> assertEq "after insert" newTe.text "Hello!"
  | _ -> TestResult.Fail "Expected Editing result"

let testTextEditorBackspace () : TestResult =
  let te = TextEditor.fromText "AB"
  match TextEditor.handleKey te (Stdlib.Cli.Stdin.Key.Key.Backspace) (Stdlib.Cli.Stdin.Modifiers.Modifiers { shift = false; ctrl = false; alt = false }) (Stdlib.Option.Option.None) with
  | Editing newTe -> assertEq "after backspace" newTe.text "A"
  | _ -> TestResult.Fail "Expected Editing result"

let testTextEditorFinish () : TestResult =
  let te = TextEditor.fromText "Done"
  match TextEditor.handleKey te (Stdlib.Cli.Stdin.Key.Key.Enter) (Stdlib.Cli.Stdin.Modifiers.Modifiers { shift = false; ctrl = false; alt = false }) (Stdlib.Option.Option.None) with
  | Finished text -> assertEq "finished text" text "Done"
  | _ -> TestResult.Fail "Expected Finished result"

let testTextEditorCancel () : TestResult =
  let te = TextEditor.fromText "Nope"
  match TextEditor.handleKey te (Stdlib.Cli.Stdin.Key.Key.Escape) (Stdlib.Cli.Stdin.Modifiers.Modifiers { shift = false; ctrl = false; alt = false }) (Stdlib.Option.Option.None) with
  | Cancelled -> TestResult.Pass
  | _ -> TestResult.Fail "Expected Cancelled result"


// --- OutlineEditor edit integration ---

let testEditMode () : TestResult =
  let outline =
    buildOutline
      [(1, "Hello")]
      []
      [1]
      2
  let editor = makeEditor outline
  let editing = OutlineEditor.enterEditMode editor
  match editing.editing with
  | Some te ->
    if te.text == "Hello" && te.cursor == 5 then TestResult.Pass
    else TestResult.Fail $"Expected 'Hello' at cursor 5"
  | None -> TestResult.Fail "Expected editing state"

let testFinishEditing () : TestResult =
  let outline =
    buildOutline
      [(1, "Old")]
      []
      [1]
      2
  let editor = makeEditor outline
  let editing = OutlineEditor.enterEditMode editor
  let committed = OutlineEditor.commitEdit editing "New"
  let text = getNodeText committed.outline 1
  assertEq "node text" text "New"


// --- Main/compositor tests ---

let testDefaultStateHasTwoDocs () : TestResult =
  let state = Main.defaultState ()
  assertInt "doc count" (Stdlib.List.length state.documents) 2

let testActiveDocReturnsCorrectDoc () : TestResult =
  let state = Main.defaultState ()
  let doc = Main.activeDoc state
  assertEq "title" doc.title "My Notes"

let testCreateDocument () : TestResult =
  let state = Main.defaultState ()
  let newState = Main.createDocument state "Third Doc"
  let count = Stdlib.List.length newState.documents
  if count == 3 && newState.activeDocId == state.nextDocId then
    let doc = Main.activeDoc newState
    assertEq "doc title" doc.title "Third Doc"
  else
    TestResult.Fail $"Expected 3 docs, got {Stdlib.Int.toString count}"

let testDeleteDocument () : TestResult =
  let state = Main.defaultState ()
  let newState = Main.createDocument state "Third"
  let thirdDocId = newState.activeDocId
  let afterDelete = Main.deleteDocument newState thirdDocId
  assertInt "doc count" (Stdlib.List.length afterDelete.documents) 2

let testDeleteOnlyDocDoesNothing () : TestResult =
  let state = makeMainState (buildOutline [(1, "X")] [] [1] 2)
  let afterDelete = Main.deleteDocument state 1
  assertInt "doc count" (Stdlib.List.length afterDelete.documents) 1

let testRenameDocument () : TestResult =
  let state = Main.defaultState ()
  let doc = Main.activeDoc state
  let renamed = Main.renameDocument state doc.id "New Title"
  let renamedDoc = Main.activeDoc renamed
  assertEq "title" renamedDoc.title "New Title"

let testExportMarkdown () : TestResult =
  let outline =
    buildOutline
      [(1, "Root"); (2, "Child")]
      [(1, [2])]
      [1]
      3
  let doc =
    Document { id = 1; title = "Test"; outline = outline }
  let md = Export.toMarkdown doc
  if Stdlib.String.contains md "# Test" && Stdlib.String.contains md "- Root" && Stdlib.String.contains md "  - Child" then
    TestResult.Pass
  else
    TestResult.Fail $"Unexpected markdown:\n{md}"

let testExportOpml () : TestResult =
  let outline =
    buildOutline
      [(1, "Root"); (2, "Child")]
      [(1, [2])]
      [1]
      3
  let doc =
    Document { id = 1; title = "Test"; outline = outline }
  let opml = Export.toOpml doc
  if Stdlib.String.contains opml "<opml" && Stdlib.String.contains opml "<title>Test</title>" && Stdlib.String.contains opml "text=\"Root\"" && Stdlib.String.contains opml "text=\"Child\"" then
    TestResult.Pass
  else
    TestResult.Fail $"Unexpected OPML:\n{opml}"

let testImportMarkdown () : TestResult =
  let md = "# My Doc\n- Alpha\n  - Beta\n- Gamma"
  let doc = Markdown.import md
  if doc.title == "My Doc" then
    let flat = flattenVisible doc.outline
    assertInt "visible count" (Stdlib.List.length flat) 3
  else
    TestResult.Fail $"Expected title 'My Doc', got '{doc.title}'"


// --- Test runner ---

let allTests () : List<(String * TestFunction)> =
  [ ("Flatten visible counts all nodes", fun () -> testFlattenVisibleCountsAllNodes ())
    ("Flatten visible respects collapse", fun () -> testFlattenVisibleRespectsCollapse ())
    ("Build outline", fun () -> testBuildOutline ())
    ("Find parent id", fun () -> testFindParentId ())
    ("Insert after adds node", fun () -> testInsertAfterAddsNode ())
    ("Insert after empty tree", fun () -> testInsertAfterEmptyTree ())
    ("Delete empty node", fun () -> testDeleteEmptyNode ())
    ("Delete non-empty does nothing", fun () -> testDeleteNonEmptyNodeDoesNothing ())
    ("Toggle collapse", fun () -> testToggleCollapse ())
    ("Toggle collapse leaf no-op", fun () -> testToggleCollapseLeafDoesNothing ())
    ("Indent node", fun () -> testIndentNode ())
    ("Outdent node", fun () -> testOutdentNode ())
    ("Move node up", fun () -> testMoveNodeUp ())
    ("Move node down", fun () -> testMoveNodeDown ())
    ("Cursor up/down", fun () -> testMoveCursorUpDown ())
    ("Cursor bounds", fun () -> testMoveCursorBounds ())
    ("TextEditor insert", fun () -> testTextEditorInsert ())
    ("TextEditor backspace", fun () -> testTextEditorBackspace ())
    ("TextEditor finish", fun () -> testTextEditorFinish ())
    ("TextEditor cancel", fun () -> testTextEditorCancel ())
    ("Edit mode", fun () -> testEditMode ())
    ("Finish editing", fun () -> testFinishEditing ())
    ("Default state has two docs", fun () -> testDefaultStateHasTwoDocs ())
    ("Active doc returns correct doc", fun () -> testActiveDocReturnsCorrectDoc ())
    ("Create document", fun () -> testCreateDocument ())
    ("Delete document", fun () -> testDeleteDocument ())
    ("Delete only doc no-op", fun () -> testDeleteOnlyDocDoesNothing ())
    ("Rename document", fun () -> testRenameDocument ())
    ("Export markdown", fun () -> testExportMarkdown ())
    ("Export OPML", fun () -> testExportOpml ())
    ("Import markdown", fun () -> testImportMarkdown ()) ]


let runAllTests () : Int =
  let tests = allTests ()

  Stdlib.printLine ""
  Stdlib.printLine "Outliner Tests"
  Stdlib.printLine "=============="

  let initialSummary =
    TestSummary
      { totalTests = 0
        passedTests = 0
        failedTests = 0
        failedTestNames = [] }

  let finalSummary =
    tests
    |> Stdlib.List.fold initialSummary (fun summary pair ->
      let (name, testFn) = pair
      let newSummary =
        { summary with totalTests = summary.totalTests + 1 }

      match testFn () with
      | Pass ->
        Stdlib.printLine $"  PASS  {name}"
        { newSummary with passedTests = newSummary.passedTests + 1 }
      | Fail message ->
        Stdlib.printLine $"  FAIL  {name}: {message}"
        { newSummary with
            failedTests = newSummary.failedTests + 1
            failedTestNames = Stdlib.List.append newSummary.failedTestNames [name] })

  Stdlib.printLine ""
  Stdlib.printLine $"Results: {Stdlib.Int.toString finalSummary.passedTests}/{Stdlib.Int.toString finalSummary.totalTests} passed"

  if finalSummary.failedTests == 0 then
    Stdlib.printLine "All tests passed!"
    0
  else
    Stdlib.printLine "Failed:"
    finalSummary.failedTestNames
    |> Stdlib.List.iter (fun name -> Stdlib.printLine $"  - {name}")
    1
