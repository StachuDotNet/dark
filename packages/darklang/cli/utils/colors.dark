module Darklang.Cli.Colors

// Basic colors and formatting
val reset = "\u001b[0m"
val bold = "\u001b[1m"
val dim = "\u001b[2m"
val italic = "\u001b[3m"
val underline = "\u001b[4m"
val reverse = "\u001b[7m"

// Cursor and line control
val clearLine = "\u001b[K"
val carriageReturn = "\r"
let moveCursorToColumn (col: Int) : String = $"\u001b[{Stdlib.Int.toString col}G"
let moveCursorUp (n: Int) : String = $"\u001b[{Stdlib.Int.toString n}A"
val saveCursor = "\u001b[s"
val restoreCursor = "\u001b[u"
/// Move cursor to absolute position (row, col). Used to jump to the status bar without disrupting where the user is typing.
let moveCursorTo (row: Int) (col: Int) : String = $"\u001b[{Stdlib.Int.toString row};{Stdlib.Int.toString col}H"
/// Define which rows can scroll. Content outside this region stays fixed. Used to keep the status bar pinned at the bottom.
let setScrollRegion (top: Int) (bottom: Int) : String = $"\u001b[{Stdlib.Int.toString top};{Stdlib.Int.toString bottom}r"
val resetScrollRegion = "\u001b[r"

// Standard colors
val black = "\u001b[30m"
val red = "\u001b[31m"
val green = "\u001b[32m"
val yellow = "\u001b[33m"
val blue = "\u001b[34m"
val magenta = "\u001b[35m"
val cyan = "\u001b[36m"
val white = "\u001b[37m"

// Bright colors
val brightBlack = "\u001b[90m"
val brightRed = "\u001b[91m"
val brightGreen = "\u001b[92m"
val brightYellow = "\u001b[93m"
val brightBlue = "\u001b[94m"
val brightMagenta = "\u001b[95m"
val brightCyan = "\u001b[96m"
val brightWhite = "\u001b[97m"

// Background colors
val bgBlack = "\u001b[40m"
val bgRed = "\u001b[41m"
val bgGreen = "\u001b[42m"
val bgYellow = "\u001b[43m"
val bgBlue = "\u001b[44m"
val bgMagenta = "\u001b[45m"
val bgCyan = "\u001b[46m"
val bgWhite = "\u001b[47m"

// Extended 256-colors (foreground)
val pink = "\x1b[38;5;213m"
val purple = "\x1b[38;5;141m"
val orange = "\x1b[38;5;208m"

// Background colors
val grayBg = "\x1b[48;5;236m"
val purpleBg = "\x1b[48;5;61m"
val magentaBg = "\x1b[48;5;134m"
val lightPinkBg = "\x1b[48;5;218m"
val pinkBg = "\x1b[48;5;176m"
val blueBg = "\x1b[48;5;38m"
val greenBg = "\x1b[48;5;115m"
val yellowBg = "\x1b[48;5;229m"
val brownBg = "\x1b[48;5;180m"
val orangeBg = "\x1b[48;5;222m"
val peachBg = "\x1b[48;5;216m"
val salmonBg = "\x1b[48;5;223m"

// Semantic colors for CLI elements
val commandColor = "\u001b[34m"
val argumentColor = "\u001b[32m"
val keywordColor = "\u001b[35m"
val stringColor = "\u001b[33m"
val numberColor = "\u001b[36m"
val commentColor = "\u001b[90m"
val errorColor = "\u001b[31m"
val warningColor = "\u001b[33m"
val successColor = "\u001b[32m"
val infoColor = "\u001b[34m"
val hintColor = "\u001b[2m"
val promptColor = "\u001b[97m"
val logoColor = "\u001b[90m"

// Interactive viewing colors
val primary = "\u001b[94m"       // bright blue for primary elements
val muted = "\u001b[90m"         // dim gray for secondary text
val accent = "\u001b[93m"        // bright yellow for highlights
val selection = "\u001b[103;30m" // yellow background with black text for selection
val completionSelection = "\u001b[44;97m" // blue background with white text

// Helper functions for applying colors
let colorize (color: String) (text: String) : String =
  $"{color}{text}{reset}"

let boldText (text: String) : String = colorize bold text
let dimText (text: String) : String = colorize dim text
let mutedText (text: String) : String = colorize muted text
let command (text: String) : String = colorize commandColor text
let argument (text: String) : String = colorize argumentColor text
let keyword (text: String) : String = colorize keywordColor text
let string (text: String) : String = colorize stringColor text
let number (text: String) : String = colorize numberColor text
let comment (text: String) : String = colorize commentColor text
let error (text: String) : String = colorize errorColor text
let warning (text: String) : String = colorize warningColor text
let success (text: String) : String = colorize successColor text
let info (text: String) : String = colorize infoColor text
let hint (text: String) : String = colorize hintColor text
let prompt (text: String) : String = colorize promptColor text
let logo (text: String) : String = colorize logoColor text