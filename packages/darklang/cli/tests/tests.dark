// --- Trace-surface regression tests ---

/// `traces help` lists the expected subcommand surface.
let testTracesHelp (): TestResult =
  let output = runWithCommand ["traces"; "help"]
  // Pick a handful of subcommands and flags shipped over the trace
  // work — if any vanish silently the test catches it.
  let expected =
    [ "list"; "view"; "tail"; "follow"; "find"; "hotspots"; "inspect"
      "gen-test"; "values"; "export"; "import"; "replay"; "delete"
      "prune"; "clear"; "--json"; "--with-trace" ]
  let missing =
    expected
    |> Stdlib.List.filter (fun s -> Stdlib.Bool.not (Stdlib.String.contains output s))
  match missing with
  | [] -> TestResult.Pass
  | _ ->
    TestResult.Fail
      $"`traces help` missing terms: {Stdlib.String.join missing ", "}"


/// Eval generates a trace; `traces tail` opens it and shows its input.
/// Exercises: TraceDval emission, expr_values storage, view-with-trace
/// renderer, traces-tail dispatch, prefix resolution.
let testTracesTailShowsLastEval (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "let x = 7L\nx"]
  let output = runWithCommand ["traces"; "tail"]
  if Stdlib.String.contains output "Handler: eval"
      && Stdlib.String.contains output "expression = \"let x = 7L"
  then
    TestResult.Pass
  else
    TestResult.Fail $"Expected eval handler + recorded input, got: {output}"


/// `traces clear` empties the store; subsequent `list` reports
/// "No traces found." Locks in the leak fix from `d2591e14c`.
let testTracesClearEmpties (): TestResult =
  let _ = runWithCommand ["eval"; "1L + 2L"]
  let _ = runWithCommand ["traces"; "clear"]
  let listOut = runWithCommand ["traces"; "list"]
  if Stdlib.String.contains listOut "No traces found." then
    TestResult.Pass
  else
    TestResult.Fail $"After clear, expected 'No traces found.' — got: {listOut}"


/// Specifically catches the `d2591e14c` leak: `clear` was leaving
/// `trace_expr_values` rows orphaned. Eval a `let` (which writes
/// expr_values), grab the id, clear, then verify `values <id>`
/// reports no values for that id. Pre-fix this would still show
/// the leftover values.
let testTracesClearAlsoClearsExprValues (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "let x = 99L\nx"]
  let listJson = runWithCommand ["traces"; "list"; "1"; "--json"]
  match Stdlib.String.split listJson "\"traceId\":\"" with
  | _ :: rest :: _ ->
    match Stdlib.String.split rest "\"" with
    | tid :: _ ->
      // Sanity: pre-clear, the trace has the let value recorded.
      let beforeOut = runWithCommand ["traces"; "values"; tid]
      if Stdlib.Bool.not (Stdlib.String.contains beforeOut "→  99") then
        TestResult.Fail
          $"Pre-clear: expected let value 99 in values output — got: {beforeOut}"
      else
        let _ = runWithCommand ["traces"; "clear"]
        let afterOut = runWithCommand ["traces"; "values"; tid]
        // Post-clear: prefix resolution will fail (no such trace),
        // OR the empty-state message. Either way `→  99` should
        // not be present.
        if Stdlib.String.contains afterOut "→  99" then
          TestResult.Fail
            $"Post-clear: expr_values still present (orphan!) — got: {afterOut}"
        else
          TestResult.Pass
    | _ -> TestResult.Fail "Couldn't parse trace id from list"
  | _ -> TestResult.Fail "List --json had no traceId field"


/// `traces stats` shows the count + timing aggregates for recent
/// traces. Eval traces all have handler "eval" so a 2-eval setup
/// should report count=2 in the stats table.
let testTracesStatsCounts (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "1L"]
  let _ = runWithCommand ["eval"; "2L"]
  let output = runWithCommand ["traces"; "stats"]
  // Output has columns "total ms │ max ms │ count │ handler" and
  // a row for `eval` with count 2. Check both the column headers
  // and the digit 2 alongside `eval`.
  if Stdlib.String.contains output "total ms"
      && Stdlib.String.contains output "count"
      && Stdlib.String.contains output "│ eval"
  then
    TestResult.Pass
  else
    TestResult.Fail $"Expected stats table with eval row — got: {output}"


/// `traces export <id>` produces well-formed JSON with the expected
/// top-level fields. Locks in the export schema.
let testTracesExportJson (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "let x = 5L\nx"]
  let listJson = runWithCommand ["traces"; "list"; "1"; "--json"]
  match Stdlib.String.split listJson "\"traceId\":\"" with
  | _ :: rest :: _ ->
    match Stdlib.String.split rest "\"" with
    | tid :: _ ->
      let exportOut = runWithCommand ["traces"; "export"; tid]
      // Required top-level fields per the export schema.
      let fields =
        [ "\"id\""; "\"handler_desc\""; "\"timestamp\""
          "\"input_value\""; "\"fn_calls\""; "\"expr_values\"" ]
      let missing =
        fields
        |> Stdlib.List.filter (fun f -> Stdlib.Bool.not (Stdlib.String.contains exportOut f))
      match missing with
      | [] -> TestResult.Pass
      | _ ->
        TestResult.Fail
          $"Export JSON missing fields: {Stdlib.String.join missing ", "}"
    | _ -> TestResult.Fail "Couldn't parse trace id from list"
  | _ -> TestResult.Fail "List --json had no traceId field"


/// `traces find <pattern>` finds traces whose recorded values
/// contain the substring. The unique-string approach makes the
/// match unambiguous regardless of any other traces.
let testTracesFindByContent (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "\"unique-token-xyz12345\""]
  let _ = runWithCommand ["eval"; "1L + 1L"]
  let output = runWithCommand ["traces"; "find"; "unique-token-xyz12345"]
  if Stdlib.String.contains output "Traces matching"
      && Stdlib.String.contains output "eval"
  then
    TestResult.Pass
  else
    TestResult.Fail $"Expected find result with eval handler — got: {output}"


/// `traces delete <id>` removes one trace including its expr_values.
/// Two traces in, delete one, assert: only the other remains; its
/// expr_values are still queryable. Locks in `ea3349481` plus the
/// `d2591e14c` cascade specifically for the single-trace delete path.
let testTracesDeleteSingle (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "let alpha = 11L\nalpha"]
  let _ = runWithCommand ["eval"; "let beta = 22L\nbeta"]
  // Latest trace = beta. Get its id, delete it; alpha should remain.
  let listJson = runWithCommand ["traces"; "list"; "1"; "--json"]
  match Stdlib.String.split listJson "\"traceId\":\"" with
  | _ :: rest :: _ ->
    match Stdlib.String.split rest "\"" with
    | betaTid :: _ ->
      let delOut = runWithCommand ["traces"; "delete"; betaTid]
      if Stdlib.Bool.not (Stdlib.String.contains delOut "Deleted trace") then
        TestResult.Fail $"Expected 'Deleted trace ...' — got: {delOut}"
      else
        // Now there's one trace (alpha) — its values should still be there.
        let listJson2 = runWithCommand ["traces"; "list"; "1"; "--json"]
        match Stdlib.String.split listJson2 "\"traceId\":\"" with
        | _ :: rest2 :: _ ->
          match Stdlib.String.split rest2 "\"" with
          | alphaTid :: _ ->
            let valuesOut = runWithCommand ["traces"; "values"; alphaTid]
            if Stdlib.String.contains valuesOut "→  11" then
              TestResult.Pass
            else
              TestResult.Fail
                $"Expected `→  11` in alpha's values — got: {valuesOut}"
          | _ -> TestResult.Fail "Couldn't parse alpha's id"
        | _ ->
          TestResult.Fail "List --json after delete had no traceId"
    | _ -> TestResult.Fail "Couldn't parse beta's id"
  | _ -> TestResult.Fail "List --json had no traceId field"


/// `view <fn> --with-trace <id>` annotates a fn that the trace
/// actually called. End-to-end test of TraceDval interpreter wiring
/// through to the source-overlay rendering. `Stdlib.Int64.clamp` has
/// two `let` bindings + two `if` branches — a clamped value of 5
/// against [1, 10] should produce non-zero annotations.
let testViewWithTraceAnnotates (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "Stdlib.Int64.clamp 5L 1L 10L"]
  let listJson = runWithCommand ["traces"; "list"; "1"; "--json"]
  match Stdlib.String.split listJson "\"traceId\":\"" with
  | _ :: rest :: _ ->
    match Stdlib.String.split rest "\"" with
    | tid :: _ ->
      let output =
        runWithCommand ["view"; "Stdlib.Int64.clamp"; "--with-trace"; tid]
      // The banner reports the count. Look for "annotated with N
      // value[s]" with N != 0 and check at least one let line is
      // annotated.
      if Stdlib.String.contains output "annotated with"
          && Stdlib.Bool.not
              (Stdlib.String.contains output "annotated with 0 values")
          && Stdlib.String.contains output "// = "
      then
        TestResult.Pass
      else
        TestResult.Fail $"Expected non-zero annotations on Int64.clamp — got: {output}"
    | _ -> TestResult.Fail "Couldn't parse trace id"
  | _ -> TestResult.Fail "List --json had no traceId field"


/// `traces prune --keep N` keeps the most-recent N and drops older
/// traces. Locks in `ea3349481` plus the `d2591e14c` cascade fix
/// (expr_values rows for dropped traces also get cleaned up).
let testTracesPruneKeep (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "let a = 1L\na"]
  let _ = runWithCommand ["eval"; "let b = 2L\nb"]
  let _ = runWithCommand ["eval"; "let c = 3L\nc"]
  // Three traces, three expr_values entries. Prune to 1.
  let pruneOut = runWithCommand ["traces"; "prune"; "--keep"; "1"]
  if Stdlib.Bool.not (Stdlib.String.contains pruneOut "Pruned 2 trace") then
    TestResult.Fail $"Expected 'Pruned 2 trace(s)' — got: {pruneOut}"
  else
    let listOut = runWithCommand ["traces"; "list"]
    // Only the most-recent trace (c=3L) should remain.
    if Stdlib.String.contains listOut "Recent traces (last 20):"
        && Stdlib.Bool.not (Stdlib.String.contains listOut "let a")
        && Stdlib.Bool.not (Stdlib.String.contains listOut "let b")
    then
      // The remaining trace's expr_values: c bound to 3.
      let listJson = runWithCommand ["traces"; "list"; "1"; "--json"]
      match Stdlib.String.split listJson "\"traceId\":\"" with
      | _ :: rest :: _ ->
        match Stdlib.String.split rest "\"" with
        | tid :: _ ->
          let valuesOut = runWithCommand ["traces"; "values"; tid]
          if Stdlib.String.contains valuesOut "→  3" then
            TestResult.Pass
          else
            TestResult.Fail
              $"Expected `→  3` in remaining trace's values — got: {valuesOut}"
        | _ -> TestResult.Fail "Couldn't parse remaining trace id"
      | _ -> TestResult.Fail "List --json had no traceId field"
    else
      TestResult.Fail $"Expected 1 remaining trace — got: {listOut}"


/// `traces replay <id> --diff` re-runs the recorded eval with current
/// code and confirms the output unchanged. Locks in `3f79d2148`'s
/// `cliTracesGetExpectedOutput` round-trip via `dvalToRepr`.
let testTracesReplayDiffMatches (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "1L + 2L"]
  let listJson = runWithCommand ["traces"; "list"; "1"; "--json"]
  match Stdlib.String.split listJson "\"traceId\":\"" with
  | _ :: rest :: _ ->
    match Stdlib.String.split rest "\"" with
    | tid :: _ ->
      let output = runWithCommand ["traces"; "replay"; tid; "--diff"]
      // Expected: "Original output: 3", "New output: 3", "✓ unchanged"
      if Stdlib.String.contains output "Original output: 3"
          && Stdlib.String.contains output "New output: 3"
          && Stdlib.String.contains output "unchanged"
      then
        TestResult.Pass
      else
        TestResult.Fail $"Expected matching replay diff — got: {output}"
    | _ -> TestResult.Fail "Couldn't parse trace id from list"
  | _ -> TestResult.Fail "List --json had no traceId field"


/// `traces inspect <eval-id>` errors clearly because eval traces
/// have a builtin top-level (e.g. `int64Add`) — no source to view.
/// Locks in the guard added in `b6d4ee657`. Without the guard, the
/// view path tries to look up `int64Add` as a package fn and surfaces
/// "Function '/int64Add. (fn)' not found" — confusing.
let testTracesInspectErrorsOnBuiltinHandler (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "1L + 2L"]
  let listJson = runWithCommand ["traces"; "list"; "1"; "--json"]
  match Stdlib.String.split listJson "\"traceId\":\"" with
  | _ :: rest :: _ ->
    match Stdlib.String.split rest "\"" with
    | tid :: _ ->
      let output = runWithCommand ["traces"; "inspect"; tid]
      if Stdlib.String.contains output "is a builtin"
          && Stdlib.String.contains output "no source to view"
      then
        TestResult.Pass
      else
        TestResult.Fail $"Expected builtin-handler error — got: {output}"
    | _ -> TestResult.Fail "Couldn't parse trace id from list"
  | _ -> TestResult.Fail "List --json had no traceId field"


/// `traces values <id>` lists `(exprId, dval)` pairs for a let-binding eval.
let testTracesValuesAfterLet (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "let x = 1L + 2L\nx"]
  let listJson = runWithCommand ["traces"; "list"; "1"; "--json"]
  // Crude id-extract — the JSON has one trace; pull the uuid via split.
  match Stdlib.String.split listJson "\"traceId\":\"" with
  | _ :: rest :: _ ->
    match Stdlib.String.split rest "\"" with
    | tid :: _ ->
      let valuesOut = runWithCommand ["traces"; "values"; tid]
      // The let RHS evaluates to `3`. Look for `→  3` in the values
      // listing (the renderer formats as "<exprId>  →  <repr>").
      if Stdlib.String.contains valuesOut "→  3" then
        TestResult.Pass
      else
        TestResult.Fail $"Expected `→  3` in values output, got: {valuesOut}"
    | _ -> TestResult.Fail $"Couldn't parse trace id from list output"
  | _ -> TestResult.Fail $"List --json had no traceId field: {listJson}"


/// Negative limits are rejected across the limit-taking commands.
/// Locks in `0dd0a0310` and `d7b6ae90c` — pre-fix, `traces list -1`
/// returned every trace because SQLite treats `LIMIT -1` as unlimited;
/// `traces stats -1` printed "Per-handler stats (last -1 traces):"
/// verbatim. Now all four representative commands reject with a
/// uniform "Limit must be ≥ 1".
let testTracesRejectsNegativeLimit (): TestResult =
  let cases =
    [ ["traces"; "list"; "-1"]
      ["traces"; "stats"; "-1"]
      ["traces"; "hotspots"; "-1"]
      ["traces"; "find"; "foo"; "-1"] ]
  let failures =
    cases
    |> Stdlib.List.filter (fun argv ->
      let out = runWithCommand argv
      Stdlib.Bool.not (Stdlib.String.contains out "Limit must be ≥ 1"))
  match failures with
  | [] -> TestResult.Pass
  | _ ->
    let names =
      failures
      |> Stdlib.List.map (fun argv -> Stdlib.String.join argv " ")
      |> Stdlib.String.join ", "
    TestResult.Fail $"Expected `Limit must be ≥ 1` from: {names}"


/// Both arg orders work for `tail` and `list` — locks in `4528749dd`
/// and `3d7f3528f`. Pre-fix `tail 1 --route eval` and
/// `list --json --fn add 5` silently fell through to global help.
let testTracesArgOrderingsWork (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "1L + 1L"]
  // `tail` accepts both orderings.
  let tailNFirst = runWithCommand ["traces"; "tail"; "1"; "--route"; "eval"]
  let tailRouteFirst = runWithCommand ["traces"; "tail"; "--route"; "eval"; "1"]
  // `list --json --fn ... <limit>` (a 5-arg form previously missing).
  let listJsonFn = runWithCommand ["traces"; "list"; "--json"; "--fn"; "add"; "5"]
  let checks =
    [ ("tail N first", tailNFirst, "Trace:")
      ("tail --route first", tailRouteFirst, "Trace:")
      ("list --json --fn add 5", listJsonFn, "[") ]
  let failures =
    checks
    |> Stdlib.List.filter (fun tup ->
      let (_, output, expected) = tup
      Stdlib.Bool.not (Stdlib.String.contains output expected))
  match failures with
  | [] -> TestResult.Pass
  | _ ->
    let names =
      failures
      |> Stdlib.List.map (fun tup ->
        let (label, _, _) = tup
        label)
      |> Stdlib.String.join "; "
    TestResult.Fail $"Arg-order forms didn't dispatch: {names}"


/// `tail --route` and `list --route` reject empty/whitespace input.
/// Locks in `ed4db8129` and `a4dde7dde`. Pre-fix `traces tail --route
/// ""` returned whatever trace was last (empty substring matches all).
let testTracesRouteEmptyRejection (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "1L + 1L"]
  let cases =
    [ ("tail empty", ["traces"; "tail"; "--route"; ""], "--route pattern must not be empty")
      ("tail whitespace", ["traces"; "tail"; "--route"; "   "], "--route pattern must not be empty")
      ("list empty", ["traces"; "list"; "--route"; ""], "--route pattern must not be empty")
      ("list-fn whitespace", ["traces"; "list"; "--fn"; "   "], "--fn pattern must not be empty") ]
  let failures =
    cases
    |> Stdlib.List.filter (fun tup ->
      let (_, argv, expected) = tup
      let out = runWithCommand argv
      Stdlib.Bool.not (Stdlib.String.contains out expected))
  match failures with
  | [] -> TestResult.Pass
  | _ ->
    let names =
      failures
      |> Stdlib.List.map (fun tup ->
        let (label, _, _) = tup
        label)
      |> Stdlib.String.join "; "
    TestResult.Fail $"Empty/whitespace --route/--fn rejection failed: {names}"


/// Malformed arity-1 commands print focused usage instead of the
/// global help dump. Locks in `d352facdc`. Pre-fix
/// `traces export <id> --frob` (length 3) silently fell through to
/// the multi-page help.
let testTracesArity1Catchalls (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "1L + 1L"]
  let listJson = runWithCommand ["traces"; "list"; "1"; "--json"]
  match Stdlib.String.split listJson "\"traceId\":\"" with
  | _ :: rest :: _ ->
    match Stdlib.String.split rest "\"" with
    | tid :: _ ->
      let cases =
        [ ("export", ["traces"; "export"; tid; "--frob"], "Usage: traces export <trace-id>")
          ("inspect", ["traces"; "inspect"; tid; "--frob"], "Usage: traces inspect <trace-id>")
          ("values", ["traces"; "values"; tid; "--frob"], "Usage: traces values <trace-id>")
          ("delete", ["traces"; "delete"; tid; "--frob"], "Usage: traces delete <trace-id>") ]
      let failures =
        cases
        |> Stdlib.List.filter (fun tup ->
          let (_, argv, expected) = tup
          let out = runWithCommand argv
          Stdlib.Bool.not (Stdlib.String.contains out expected))
      match failures with
      | [] -> TestResult.Pass
      | _ ->
        let names =
          failures
          |> Stdlib.List.map (fun tup ->
            let (label, _, _) = tup
            label)
          |> Stdlib.String.join "; "
        TestResult.Fail $"Catch-all didn't fire for: {names}"
    | _ -> TestResult.Fail "Couldn't parse trace id"
  | _ -> TestResult.Fail "List --json had no traceId field"


/// `traces stats` hides the `--route` drill-down hint when there
/// are no HTTP handlers (i.e., only eval/run traces). Locks in
/// `7731c497d`.
let testTracesStatsHintHiddenForEvalOnly (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "1L + 1L"]
  let _ = runWithCommand ["eval"; "2L + 2L"]
  let statsOut = runWithCommand ["traces"; "stats"]
  // Expect the per-handler table to render but NOT the route hint —
  // there are no HTTP handlers in the store.
  if Stdlib.String.contains statsOut "Per-handler stats"
      && Stdlib.String.contains statsOut "eval"
      && Stdlib.Bool.not
          (Stdlib.String.contains statsOut "drill into a route")
  then
    TestResult.Pass
  else
    TestResult.Fail
      $"Expected stats without --route hint for eval-only store. Got: {statsOut}"


/// Unknown subcommand prints a clear error before the help dump.
/// Locks in `ee648b93d`. Pre-fix `traces lst` (typo) silently dumped
/// help with no indication the user's input was unrecognized.
let testTracesUnknownSubcommandSurfaced (): TestResult =
  let typoOut = runWithCommand ["traces"; "nonsense"]
  let typoTwoOut = runWithCommand ["traces"; "lst"]
  // Bare `traces` and `traces help` should NOT be flagged as unknown —
  // they go straight to help.
  let bareOut = runWithCommand ["traces"]
  let helpOut = runWithCommand ["traces"; "help"]
  if Stdlib.String.contains typoOut "Unknown subcommand: nonsense"
      && Stdlib.String.contains typoTwoOut "Unknown subcommand: lst"
      && Stdlib.Bool.not (Stdlib.String.contains bareOut "Unknown subcommand")
      && Stdlib.Bool.not (Stdlib.String.contains helpOut "Unknown subcommand")
  then
    TestResult.Pass
  else
    TestResult.Fail
      $"Unexpected unknown-subcommand output. typo: {typoOut}; bare: {bareOut}"


/// `list --route` and `view --filter` match case-insensitively. Locks
/// in `5dd80c793` and `52afd47e6` — pre-fix the user got silently
/// empty output if their case didn't match the recorded handler /
/// fn name.
let testTracesFiltersAreCaseInsensitive (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "1L + 1L"]
  let listLower = runWithCommand ["traces"; "list"; "--route"; "eval"]
  let listUpper = runWithCommand ["traces"; "list"; "--route"; "EVAL"]
  let listMixed = runWithCommand ["traces"; "list"; "--route"; "Eval"]
  // All three should find the recorded eval trace.
  if Stdlib.String.contains listLower "eval"
      && Stdlib.String.contains listUpper "eval"
      && Stdlib.String.contains listMixed "eval"
      && Stdlib.Bool.not
          (Stdlib.String.contains listUpper "No traces found")
  then
    TestResult.Pass
  else
    TestResult.Fail
      $"Expected case-insensitive route match. lower: {listLower}; upper: {listUpper}; mixed: {listMixed}"


/// Empty pattern in find / list --fn / list --route is rejected
/// instead of silently matching everything. Locks in `7ca47e1b6` and
/// `cd357484f`. Pre-fix `traces find ""` printed "Traces matching ''
/// (last 20):" with every trace.
let testTracesRejectsEmptyPattern (): TestResult =
  let cases =
    [ ("find empty", ["traces"; "find"; ""], "find pattern must not be empty")
      ("find empty --view", ["traces"; "find"; ""; "--view"], "find pattern must not be empty")
      ("find empty --json", ["traces"; "find"; ""; "--json"], "find pattern must not be empty")
      ("list --fn empty", ["traces"; "list"; "--fn"; ""], "--fn pattern must not be empty")
      ("list --route empty", ["traces"; "list"; "--route"; ""], "--route pattern must not be empty") ]
  let failures =
    cases
    |> Stdlib.List.filter (fun tup ->
      let (_, argv, expected) = tup
      let out = runWithCommand argv
      Stdlib.Bool.not (Stdlib.String.contains out expected))
  match failures with
  | [] -> TestResult.Pass
  | _ ->
    let names =
      failures
      |> Stdlib.List.map (fun tup ->
        let (label, _, _) = tup
        label)
      |> Stdlib.String.join "; "
    TestResult.Fail $"Empty-pattern rejection failed for: {names}"


/// `view` sub-options reject negative values explicitly. Locks in
/// `d7b7230e1` — pre-fix `--depth -1` and `--slow-ms -1` parsed as
/// valid Int64 and were silently accepted with meaningless semantics.
let testTracesViewRejectsNegativeSubOptions (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "1L + 1L"]
  let listJson = runWithCommand ["traces"; "list"; "1"; "--json"]
  match Stdlib.String.split listJson "\"traceId\":\"" with
  | _ :: rest :: _ ->
    match Stdlib.String.split rest "\"" with
    | tid :: _ ->
      let depthOut =
        runWithCommand ["traces"; "view"; tid; "--depth"; "-1"]
      let slowOut =
        runWithCommand ["traces"; "view"; tid; "--slow-ms"; "-1"]
      if Stdlib.String.contains depthOut "--depth must be ≥ 0"
          && Stdlib.String.contains slowOut "--slow-ms must be ≥ 0"
      then
        TestResult.Pass
      else
        TestResult.Fail
          $"Expected `must be ≥ 0` rejection from both. depth: {depthOut}; slow-ms: {slowOut}"
    | _ -> TestResult.Fail "Couldn't parse trace id"
  | _ -> TestResult.Fail "List --json had no traceId field"


/// Result-message phrasing matches the actual count: singular when
/// 1, plural when N. And `prune --keep 0` says "none kept", not
/// "kept the 0 most-recent". Locks in `49a0cfec9` and `3c81ed512`.
let testTracesClearAndPruneGrammar (): TestResult =
  let _ = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "1L + 1L"]
  let clearOne = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "1L + 1L"]
  let _ = runWithCommand ["eval"; "2L + 2L"]
  let clearTwo = runWithCommand ["traces"; "clear"]
  let _ = runWithCommand ["eval"; "1L + 1L"]
  let _ = runWithCommand ["eval"; "2L + 2L"]
  let pruneNone = runWithCommand ["traces"; "prune"; "--keep"; "0"]
  let _ = runWithCommand ["eval"; "3L + 3L"]
  let _ = runWithCommand ["eval"; "4L + 4L"]
  let pruneOne = runWithCommand ["traces"; "prune"; "--keep"; "1"]
  let checks =
    [ ("clear 1 → singular", clearOne, "Cleared 1 trace.")
      ("clear 2 → plural", clearTwo, "Cleared 2 traces.")
      ("prune keep 0 → none kept", pruneNone, "none kept")
      ("prune keep 1 → most-recent", pruneOne, "kept the most-recent") ]
  let failures =
    checks
    |> Stdlib.List.filter (fun tup ->
      let (_, output, expected) = tup
      Stdlib.Bool.not (Stdlib.String.contains output expected))
  match failures with
  | [] -> TestResult.Pass
  | _ ->
    let names =
      failures
      |> Stdlib.List.map (fun tup ->
        let (label, _, _) = tup
        label)
      |> Stdlib.String.join "; "
    TestResult.Fail $"Phrasing checks failed: {names}"


/// Flag-shaped input where a trace ID was expected is rejected as a
/// flag, not silently passed to the resolver. Locks in `f57c4aea3`.
/// Pre-fix: `traces export --frob` said "Trace not found: --frob".
let testTracesRejectsFlagAsTraceId (): TestResult =
  let cases =
    [ ["traces"; "export"; "--frob"]
      ["traces"; "inspect"; "--frob"]
      ["traces"; "values"; "--frob"]
      ["traces"; "replay"; "--frob"]
      ["traces"; "delete"; "--frob"]
      ["traces"; "gen-test"; "--frob"] ]
  let failures =
    cases
    |> Stdlib.List.filter (fun argv ->
      let out = runWithCommand argv
      Stdlib.Bool.not (Stdlib.String.contains out "Unknown flag: --frob"))
  match failures with
  | [] -> TestResult.Pass
  | _ ->
    let names =
      failures
      |> Stdlib.List.map (fun argv -> Stdlib.String.join argv " ")
      |> Stdlib.String.join ", "
    TestResult.Fail $"Expected `Unknown flag: --frob` from: {names}"


type TestFunction = Unit -> TestResult

let allTests (): List<String * TestFunction> =
  [ ("Help", fun () -> testHelpCommand ())
    ("Version", fun () -> testVersionCommand ())
    ("Status", fun () -> testStatusCommand ())

    ("Run Bool.and", fun () -> testRunBoolAnd ())
    ("Run Int64.add", fun () -> testRunInt64Add ())

    ("Eval String Length", fun () -> testEvalStringLength ())
    ("Eval List Length", fun () -> testEvalListLength ())

    ("List Functions", fun () -> testListFunctions ())
    ("View Function", fun () -> testViewFunction ())
    ("List Types", fun () -> testListTypes ())

    ("Help for Run", fun () -> testHelpForRun ())
    ("Help for Ls", fun () -> testHelpForLs ())

    ("Eval Simple Expression", fun () -> testEvalSimpleExpression ())
    ("Eval String Expression", fun () -> testEvalStringExpression ())

    ("Traces Help", fun () -> testTracesHelp ())
    ("Traces Tail Shows Last Eval", fun () -> testTracesTailShowsLastEval ())
    ("Traces Values After Let", fun () -> testTracesValuesAfterLet ())
    ("Traces Clear Empties", fun () -> testTracesClearEmpties ())
    ("Traces Clear Also Clears Expr Values",
      fun () -> testTracesClearAlsoClearsExprValues ())
    ("Traces Stats Counts", fun () -> testTracesStatsCounts ())
    ("Traces Export JSON Schema", fun () -> testTracesExportJson ())
    ("Traces Find By Content", fun () -> testTracesFindByContent ())
    ("Traces Delete Single", fun () -> testTracesDeleteSingle ())
    ("View With Trace Annotates", fun () -> testViewWithTraceAnnotates ())
    ("Traces Prune Keep", fun () -> testTracesPruneKeep ())
    ("Traces Replay Diff Matches", fun () -> testTracesReplayDiffMatches ())
    ("Traces Rejects Negative Limit",
      fun () -> testTracesRejectsNegativeLimit ())
    ("Traces Rejects Flag As Trace Id",
      fun () -> testTracesRejectsFlagAsTraceId ())
    ("Traces Clear And Prune Grammar",
      fun () -> testTracesClearAndPruneGrammar ())
    ("Traces View Rejects Negative Sub Options",
      fun () -> testTracesViewRejectsNegativeSubOptions ())
    ("Traces Rejects Empty Pattern",
      fun () -> testTracesRejectsEmptyPattern ())
    ("Traces Filters Are Case Insensitive",
      fun () -> testTracesFiltersAreCaseInsensitive ())
    ("Traces Unknown Subcommand Surfaced",
      fun () -> testTracesUnknownSubcommandSurfaced ())
    ("Traces Stats Hint Hidden For Eval Only",
      fun () -> testTracesStatsHintHiddenForEvalOnly ())
    ("Traces Arg Orderings Work",
      fun () -> testTracesArgOrderingsWork ())
    ("Traces Arity 1 Catchalls",
      fun () -> testTracesArity1Catchalls ())
    ("Traces Route Empty Rejection",
      fun () -> testTracesRouteEmptyRejection ())
    ("Traces Inspect Errors On Builtin Handler",
      fun () -> testTracesInspectErrorsOnBuiltinHandler ())
  ]

type TestSummary =
  { totalTests: Int64
    passedTests: Int64
    failedTests: Int64
    failedTestNames: List<String> }

// Sequential test execution - proven to be ~30-50% faster than parallel for CLI tests
// due to process startup overhead and resource contention
let runAllTests (): Int64 =
  let tests = allTests ()

  Stdlib.printLine ""
  Stdlib.printLine "Darklang CLI Tests"
  Stdlib.printLine "=================="

  let initialSummary =
    TestSummary
      { totalTests = 0L
        passedTests = 0L
        failedTests = 0L
        failedTestNames = [] }

  let finalSummary =
    tests
    |> Stdlib.List.fold initialSummary (fun summary (name, testFn) ->
      Stdlib.printLine ""
      Stdlib.printLine $"Running: {name} ..."

      let newSummary =
        { summary with totalTests = summary.totalTests + 1L }

      match testFn () with
      | Pass ->
        Stdlib.printLine $"✓ PASS - {name}"
        { newSummary with passedTests = newSummary.passedTests + 1L }
      | Fail message ->
        Stdlib.printLine $"✗ FAIL - {name}"
        Stdlib.printLine $"  Reason: {message}"
        { newSummary with
            failedTests = newSummary.failedTests + 1L
            failedTestNames = Stdlib.List.push newSummary.failedTestNames name })

  Stdlib.printLine ""
  Stdlib.printLine "📊 Test Results Summary"
  Stdlib.printLine "======================"
  Stdlib.printLine $"Total tests:  {Stdlib.Int64.toString finalSummary.totalTests}"
  Stdlib.printLine $"Passed:       {Stdlib.Int64.toString finalSummary.passedTests}"
  Stdlib.printLine $"Failed:       {Stdlib.Int64.toString finalSummary.failedTests}"

  if finalSummary.failedTests == 0L then
    Stdlib.printLine "🎉 All tests passed!"
    0L
  else
    Stdlib.printLine "🚨 Some tests failed!"
    if Stdlib.Bool.not (Stdlib.List.isEmpty finalSummary.failedTestNames) then
      Stdlib.printLine "Failed tests:"
      finalSummary.failedTestNames
      |> Stdlib.List.iter (fun testName ->
        Stdlib.printLine $"  ✗ {testName}")
    1L
