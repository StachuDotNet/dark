module Darklang.Cli.SCM.Log


// `dark commits` — what's been committed on this branch and the ones it came from.
//
// One line per commit by default. The three-line-per-commit form (id/date/author, then the message on its
// own indented line, then a blank) meant six commits filled the screen, and the blank lines were separating
// things that didn't need separating. `--detailed` still gives you that when you're reading one closely.

let renderOneLine
  (c: SCM.PackageOps.Commit)
  (isAncestor: Bool)
  : String =
  let id = LanguageTools.ProgramTypes.hashToShort c.hash
  let createdAt = Stdlib.DateTime.toString c.createdAt
  let opCount = Stdlib.Int.toString c.opCount
  let suffix = if isAncestor then $"  [{c.branchName}]" else ""

  if isAncestor then
    $"{Cli.Colors.dim}  {id}  {createdAt}  {opCount} ops  {c.message}{suffix}{Cli.Colors.reset}"
  else
    $"  {Cli.Colors.cyan}{id}{Cli.Colors.reset}  {createdAt}  {opCount} ops  {c.message}"

let renderDetailed (c: SCM.PackageOps.Commit) (isAncestor: Bool) : Unit =
  let id = LanguageTools.ProgramTypes.hashToShort c.hash
  let createdAt = Stdlib.DateTime.toString c.createdAt
  let opCount = Stdlib.Int.toString c.opCount

  if isAncestor then
    Stdlib.printLine
      $"{Cli.Colors.dim}{id}  {createdAt}  {c.committerName}  ({opCount} ops)  [{c.branchName}]{Cli.Colors.reset}"

    Stdlib.printLine $"{Cli.Colors.dim}    {c.message}{Cli.Colors.reset}"
  else
    Stdlib.printLine
      $"{Cli.Colors.cyan}{id}{Cli.Colors.reset}  {createdAt}  {Cli.Colors.dim}{c.committerName}{Cli.Colors.reset}  ({opCount} ops)"

    Stdlib.printLine $"    {c.message}"

  Stdlib.printLine ""

let execute (state: AppState) (args: List<String>) : AppState =
  let branchId = state.currentBranchId
  let detailed =
    (Stdlib.List.member args "--detailed") || (Stdlib.List.member args "--full")

  let limit =
    match Stdlib.List.filter args (fun a -> Stdlib.String.startsWith a "--" |> Stdlib.Bool.not) with
    | [ limitStr ] ->
      match Stdlib.Int.parse limitStr with
      | Ok n -> n
      | Error _ -> 20
    | _ -> 20

  let commits = SCM.PackageOps.getCommitsWithAncestors branchId limit
  let currentBranchIdStr = Stdlib.Uuid.toString branchId

  if Stdlib.List.isEmpty commits then
    Stdlib.printLine "No commits yet."
  else
    let branchName =
      match SCM.Branch.get branchId with
      | Some b -> b.name
      | None -> "unknown"

    // Say what you're looking at. The bare list left you to infer both the branch and that commits from
    // parent branches are in here too (the dimmed ones).
    Stdlib.printLine (
      Cli.Colors.success
        $"Commits on {branchName} ({Stdlib.Int.toString (Stdlib.List.length commits)}, newest first):")

    commits
    |> Stdlib.List.iter (fun c ->
      let commitBranchId = Stdlib.Uuid.toString c.branchId
      let isAncestor = commitBranchId != currentBranchIdStr && commitBranchId != ""

      if detailed then
        renderDetailed c isAncestor
      else
        Stdlib.printLine (renderOneLine c isAncestor))

  state


let complete (_state: AppState) (_args: List<String>) : List<Completion.CompletionItem> =
  []


let help (_state: AppState) : Unit =
  [ "Usage: commits [limit] [--detailed]"
    "Show commit history for the current branch and its ancestors."
    "Commits from parent branches are shown dimmed with the branch name."
    ""
    "Arguments:"
    "  limit        Maximum number of commits to show (default: 20)"
    "  --detailed   Three lines per commit (id/date/author, message, blank) instead of one."
    "               --full does the same."
    ""
    "Aliases: log, history"
    ""
    "Use 'show <commit-id>' to see details of a specific commit." ]
  |> Stdlib.printLines
