module Darklang.LanguageTools.Parser.Parse


let initialParse
  (code: String)
  : Stdlib.Result.Result<WrittenTypes.ParsedFile, String> =
  // The range-complete parser. Every consumer of this fn — canvas modules,
  // CLI scripts, the package-test runner, parsePTExpr — parses through it.
  match Builtin.parserParseToWrittenTypes code with
  | Some parsedFile -> Stdlib.Result.Result.Ok parsedFile
  | None -> Stdlib.Result.Result.Error "parse failed"


// TODO: maybe use a proper type instead of string?
let parsePTExpr
  (code: String)
  : Stdlib.Result.Result<ProgramTypes.Expr, String> =
  // context-free lowering is just the in-context lowering with an empty context
  parsePTExprInContext "" [] [] [] code


// Like `parsePTExpr`, but lowers under a real module / fn-name / parameter context.
// The LoweringDifferential uses this so it can catch resolution-context-dependent
// divergences (pipe callee resolves fn-first, self-recursion → ESelf, a match
// pattern shadowing a parameter) that a context-free lowering can't surface.
let parsePTExprInContext
  (owner: String)
  (currentModule: List<String>)
  // empty = no self-context (None); non-empty = Some (the fully-qualified fn name)
  (currentFnName: List<String>)
  (paramNames: List<String>)
  (code: String)
  : Stdlib.Result.Result<ProgramTypes.Expr, String> =
  match code |> initialParse with
  | Ok sourceFile ->
    let exprs =
      match sourceFile with
      | SourceFile s -> s.exprsToEval

    let ctx =
      NameResolver.NRContext
        { onMissing = NameResolver.OnMissing.Allow
          pm = PackageManager.pm ()
          branchId = Builtin.scmMainBranchId
          owner = owner
          currentModule = currentModule }

    let argMap =
      paramNames
      |> Stdlib.List.indexedMap (fun i name -> (name, i))
      |> Stdlib.List.fold Stdlib.Dict.empty (fun acc (name, idx) ->
        Stdlib.Dict.set acc name idx)

    let wtCtx =
      WrittenTypesToProgramTypes.Context
        { currentFnName =
            if Stdlib.List.isEmpty currentFnName then
              Stdlib.Option.Option.None
            else
              Stdlib.Option.Option.Some currentFnName
          argMap = argMap
          localBindings = [] }

    match exprs with
    | [ expr ] ->
      let (expr, _) = WrittenTypesToProgramTypes.Expr.toPT ctx wtCtx expr
      expr |> Stdlib.Result.Result.Ok
    | _ ->
      "Expected exactly one expression to be parsed"
      |> Stdlib.Result.Result.Error
  | Error e -> Stdlib.Result.Result.Error e


let parsePTSourceFileWithOps
  (code: String)
  : Stdlib.Result.Result<
    (ProgramTypes.SourceFile.SourceFile * List<ProgramTypes.PackageOp>),
    String
  > =
  match code |> initialParse with
  | Ok parsedFile ->
    let (sourceFile, ops, _unresolvedNames) =
      parsedFile |> WrittenTypesToProgramTypes.parsedFileAsSourceFile

    (sourceFile, ops) |> Stdlib.Result.Result.Ok
  | Error e -> Stdlib.Result.Result.Error e
