module Darklang =
  module Test =
    module EArgTests =
      let addTwo (earg1: Int) (earg2: Int): Int =
        Stdlib.Int.add earg1 earg2

      let shadowTest (shadowedEarg: Int): Int =
        let shadowedEarg = 42
        shadowedEarg  // This should be EVariable, not EArg after shadowing

      let argAndLocalVar (mixedEarg: Int): Int =
        let localVarNotEarg = 10
        Stdlib.Int.add mixedEarg localVarNotEarg  // mixedEarg=EArg(0), localVarNotEarg=EVariable("localVarNotEarg")

      let nestedShadowing (eargOne: Int) (eargTwo: Int): Int =
        let a =
          let eargOne = 100
          Stdlib.Int.add eargOne eargTwo
        Stdlib.Int.add a eargOne

      let lambdaTest (eargX: Int) : Int =
        let addX = (fun x -> Stdlib.Int.add x 1)
        let result = eargX + (addX eargX)
        result

      let matchArgName (value: Int) : Int =
        match value with
        | 0 -> 100
        | value -> value * 2

      let matchWithNestedShadowing (x: Int) (y: Int) : Int =
        match x with
        | 0 -> y
        | x -> // This 'x' shadows the parameter
          let y = x * 3  // This 'y' shadows the second parameter
          match y with
          | 6 -> 600
          | y -> y + 10  // This 'y' shadows both parameter and let binding

      let matchWithNestedShadowing2 (x: Int) (y: Int) : Int =
        match y with
        | 0 -> y
        | x -> x * 3  // This 'x' shadows the first parameter


      let tupleMatchWithArgShadowing (data: (Int * String)) : String =
        match data with
        | (0, result) -> result
        | (1, data) -> data ++ "_modified"  // 'data' shadows the parameter
        | (data, text) -> (Stdlib.Int.toString data) ++ "_" ++ text  // 'data' shadows parameter




let test1 = (Darklang.Test.EArgTests.addTwo 3 4) == 7
let test2 = (Darklang.Test.EArgTests.shadowTest 999) == 42
let test3 = (Darklang.Test.EArgTests.argAndLocalVar 5) == 15
let test4 = (Darklang.Test.EArgTests.nestedShadowing 1 2) == 103
let test5 = (Darklang.Test.EArgTests.lambdaTest 10) == 21
let test6 = (Darklang.Test.EArgTests.matchArgName 0) == 100
let test7 = (Darklang.Test.EArgTests.matchArgName 5) == 10
let test8 = (Darklang.Test.EArgTests.matchWithNestedShadowing 0 42) == 42
let test9 = (Darklang.Test.EArgTests.matchWithNestedShadowing 3 99) == 19
let test10 = (Darklang.Test.EArgTests.matchWithNestedShadowing2 5 0) == 0
let test11 = (Darklang.Test.EArgTests.matchWithNestedShadowing2 5 4) == 12
let test12 = (Darklang.Test.EArgTests.tupleMatchWithArgShadowing (0, "hello")) == "hello"
let test13 = (Darklang.Test.EArgTests.tupleMatchWithArgShadowing (1, "test")) == "test_modified"
let test14 = (Darklang.Test.EArgTests.tupleMatchWithArgShadowing (42, "data")) == "42_data"

let testList = [ test1; test2; test3; test4; test6; test7; test8; test9; test10; test11; test12; test13; test14 ]


match Stdlib.List.all testList Stdlib.Fun.identity with
| true -> 0
| false -> 1