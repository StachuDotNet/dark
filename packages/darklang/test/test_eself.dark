module Darklang =
  module Test =
    let factorial (n: Int): Int =
      if Stdlib.Int.lessThanOrEqualTo n 1 then
        1
      else
      Stdlib.Int.multiply n (Test.factorial (Stdlib.Int.subtract n 1))


    let fibonacci (n: Int): Int =
      if Stdlib.Int.lessThanOrEqualTo n 1 then
        n
      else
        Stdlib.Int.add
          (Test.fibonacci (Stdlib.Int.subtract n 1))
          (Test.fibonacci (Stdlib.Int.subtract n 2))


    let sumUpTo (n: Int): Int =
      if Stdlib.Int.lessThanOrEqualTo n 0 then
        0
      else
        Stdlib.Int.add n (Test.sumUpTo (Stdlib.Int.subtract n 1))


  module ShadowingTest =
    let incrementWithShadowing (y: Int) (z: Int): Int =
      if Stdlib.Int.lessThanOrEqualTo z 0 then
        y
      else
        let result =
          incrementWithShadowing y (Stdlib.Int.subtract z 1)

        let incrementWithShadowing =
          (fun x -> Stdlib.Int.add x 2)

        Stdlib.Int.add result (incrementWithShadowing z)


    let factorialWithShadowing (n: Int): (String * Int) =
      if Stdlib.Int.lessThanOrEqualTo n 1 then
        ("base_case", 1)
      else
        let factorialWithShadowing = "shadowed"
        let result = Stdlib.Int.multiply n ((Darklang.ShadowingTest.factorialWithShadowing (Stdlib.Int.subtract n 1)) |> Stdlib.Tuple2.second)
        (factorialWithShadowing , result)


    let matchWithShadowing (x: Int) : Int =
      match x with
      | 0 -> 0
      | 1 -> matchWithShadowing 0
      | 2 ->
        let matchWithShadowing = (fun v -> v * 4)
        matchWithShadowing 2
      | matchWithShadowing -> matchWithShadowing + 1


    let tupleMatchWithShadowing (x: (Int * Int)) : Int =
      match x with
      | (0, _) -> 0
      | (1, n) -> tupleMatchWithShadowing ((0, n))
      | (2, v) ->
          let tupleMatchWithShadowing = (fun x -> x * 10)
          tupleMatchWithShadowing v
      | (a, tupleMatchWithShadowing) -> a + tupleMatchWithShadowing


    let letBindingShadowing (x: Int) : List<Int> =
      let letBindingShadowing = (fun v -> v * 3)
      let letBindingShadowing = [ 10; letBindingShadowing x ]
      let letBindingShadowing = Stdlib.List.reverse letBindingShadowing
      letBindingShadowing


    let conditionalShadowing (x: Int) : Int =
      if x <= 0 then
        0
      else if x < 3 then
        let conditionalShadowing = (fun v w -> v * 5 + w)
        conditionalShadowing x 2
      else if x < 5 then
        let conditionalShadowing = (fun v -> v * 3)
        conditionalShadowing x
      else
        x + (conditionalShadowing (x - 1))


    let pipeWithShadowing (x: Int) : Int =
      match x with
      | 0 -> 0
      | 1 -> 0 |> pipeWithShadowing
      | 2 ->
        let pipeWithShadowing = (fun v -> v * 6)
        x |> pipeWithShadowing
      | pipeWithShadowing -> x |> Stdlib.Int.add pipeWithShadowing


    val valueShadowing = 120
    let valueShadowing (x: Int) : Int =
      if x <= 0 then
        10
      else if x == 1 then
        (valueShadowing 0) + 1
      else
        let result = valueShadowing + 1
        (valueShadowing (x - 1)) + result


let test1 = (Darklang.Test.factorial 0) == 1
let test2 = (Darklang.Test.factorial 1) == 1
let test3 = (Darklang.Test.factorial 5) == 120
let test4 = (Darklang.Test.factorial 10) == 3628800


let test5 = (Darklang.Test.fibonacci 0) == 0
let test6 = (Darklang.Test.fibonacci 1) == 1
let test7 = (Darklang.Test.fibonacci 5) == 5
let test8 = (Darklang.Test.fibonacci 10) == 55


let test9 = (Darklang.Test.sumUpTo 0) == 0
let test10 = (Darklang.Test.sumUpTo 1) == 1
let test11 = (Darklang.Test.sumUpTo 5) == 15
let test12 = (Darklang.Test.sumUpTo 10) == 55


let test13 = (Darklang.ShadowingTest.incrementWithShadowing 3 5) == 28
let test14 = (Darklang.ShadowingTest.factorialWithShadowing 5) == ("shadowed", 120)
let test15 = (Darklang.ShadowingTest.matchWithShadowing 0) == 0
let test16 = (Darklang.ShadowingTest.matchWithShadowing 1) == 0
let test17 = (Darklang.ShadowingTest.matchWithShadowing 2) == 8
let test18 = (Darklang.ShadowingTest.matchWithShadowing 5) == 6

let test19 = (Darklang.ShadowingTest.tupleMatchWithShadowing (0, 10)) == 0
let test20 = (Darklang.ShadowingTest.tupleMatchWithShadowing (1, 20)) == 0
let test21 = (Darklang.ShadowingTest.tupleMatchWithShadowing (2, 3)) == 30
let test22 = (Darklang.ShadowingTest.tupleMatchWithShadowing (4, 5)) == 9

let test23 = (Darklang.ShadowingTest.letBindingShadowing 4) == [12; 10]
let test24 = (Darklang.ShadowingTest.letBindingShadowing 5) == [15; 10]

let test25 = (Darklang.ShadowingTest.conditionalShadowing 0) == 0
let test26 = (Darklang.ShadowingTest.conditionalShadowing 1) == 7
let test27 = (Darklang.ShadowingTest.conditionalShadowing 2) == 12
let test28 = (Darklang.ShadowingTest.conditionalShadowing 3) == 9
let test29 = (Darklang.ShadowingTest.conditionalShadowing 4) == 12
let test30 = (Darklang.ShadowingTest.conditionalShadowing 5) == 17
let test31 = (Darklang.ShadowingTest.conditionalShadowing 6) == 23

let test32 = (Darklang.ShadowingTest.pipeWithShadowing 0) == 0
let test33 = (Darklang.ShadowingTest.pipeWithShadowing 1) == 0
let test34 = (Darklang.ShadowingTest.pipeWithShadowing 2) == 12
let test35 = (Darklang.ShadowingTest.pipeWithShadowing 5) == 10

let test36 = (Darklang.ShadowingTest.valueShadowing 0) == 10
let test37 = (Darklang.ShadowingTest.valueShadowing 1) == 11
let test38 = (Darklang.ShadowingTest.valueShadowing 5) == 495

let testList = [ test1; test2; test3; test4; test5; test6; test7; test8; test9; test10; test11; test12; test13; test14; test15; test16; test17; test18; test19; test20; test21; test22; test23; test24; test25; test26; test27; test28; test29; test30; test31; test32; test33; test34; test35; test36; test37; test38]

match Stdlib.List.all testList Stdlib.Fun.identity with
| true -> 0
| false -> 1