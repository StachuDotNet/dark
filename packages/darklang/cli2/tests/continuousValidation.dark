module Darklang =
  module Cli2 =
    module Tests =
      module ContinuousValidation =
        /// Continuous validation for CLI2 development
        /// Quick smoke tests to run frequently during development

        /// Quick smoke test results
        type SmokeTestResult =
          { testName: String
            passed: Bool
            message: String }

        /// Run quick smoke tests for CLI2
        let runSmokeTests (): List<SmokeTestResult> =
          [
            // Test that all CLI2 modules can be loaded
            { testName = "CLI2 Modules Load"
              passed = true  // If we're here, modules loaded successfully
              message = "All CLI2 modules loaded without syntax errors" }

            // Test that enhanced commands can be retrieved
            let testState = createTestState ()
            let systemCommands = 
              try
                let cmds = Darklang.Cli2.Commands.System.getEnhancedCommands testState
                Stdlib.List.length cmds > 0L
              with _ -> false

            { testName = "System Commands Available"
              passed = systemCommands
              message = if systemCommands then "System commands accessible" else "System commands not accessible" }

            let navigationCommands = 
              try
                let cmds = Darklang.Cli2.Commands.Navigation.getEnhancedCommands testState
                Stdlib.List.length cmds > 0L
              with _ -> false

            { testName = "Navigation Commands Available"
              passed = navigationCommands
              message = if navigationCommands then "Navigation commands accessible" else "Navigation commands not accessible" }

            let developmentCommands = 
              try
                let cmds = Darklang.Cli2.Commands.Development.getEnhancedCommands testState
                Stdlib.List.length cmds > 0L
              with _ -> false

            { testName = "Development Commands Available"
              passed = developmentCommands
              message = if developmentCommands then "Development commands accessible" else "Development commands not accessible" }

            // Test that help system works
            let helpWorks = 
              try
                let helpCmd = Darklang.Cli2.Commands.System.helpCommand
                let (newState, msgs) = helpCmd.execute testState ""
                match newState.commandResult with
                | CommandResult.Info _ -> true
                | _ -> false
              with _ -> false

            { testName = "Help System Works"
              passed = helpWorks
              message = if helpWorks then "Enhanced help system functional" else "Enhanced help system broken" }

            // Test that view handlers don't crash
            let viewHandlersWork = 
              try
                let (newState, msgs) = Darklang.Cli2.Commands.ViewHandlers.executeViewCommand testState ""
                match newState.commandResult with
                | CommandResult.Info _ -> true  // Expected for empty args
                | _ -> false
              with _ -> false

            { testName = "View Handlers Work"
              passed = viewHandlersWork
              message = if viewHandlersWork then "View handlers functional" else "View handlers broken" }
          ]

        /// Print smoke test results
        let printSmokeTestResults (results: List<SmokeTestResult>): Unit =
          let passedCount = results |> Stdlib.List.filter (fun r -> r.passed) |> Stdlib.List.length
          let totalCount = Stdlib.List.length results

          Builtin.printLine ""
          Builtin.printLine "🚀 CLI2 Continuous Validation - Smoke Tests"
          Builtin.printLine "============================================"
          Builtin.printLine $"Status: {passedCount}/{totalCount} tests passed"
          Builtin.printLine ""

          results
          |> Stdlib.List.iter (fun result ->
            let status = if result.passed then "✅" else "❌"
            Builtin.printLine $"{status} {result.testName}: {result.message}")

          Builtin.printLine ""
          if passedCount == totalCount then
            Builtin.printLine "🎉 All smoke tests passed! CLI2 development environment healthy."
          else
            Builtin.printLine "⚠️  Some smoke tests failed. Check CLI2 module structure."
          Builtin.printLine "============================================"

        /// Quick validation entry point for development
        let quickValidation (): Int64 =
          let smokeResults = runSmokeTests ()
          printSmokeTestResults smokeResults
          
          let allPassed = smokeResults |> Stdlib.List.forall (fun r -> r.passed)
          if allPassed then 0L else 1L

        /// Development workflow validation
        let validateDevelopmentState (): Unit =
          Builtin.printLine "🔍 Validating CLI2 development state..."
          
          // Check that all expected files exist and are structured correctly
          let testState = createTestState ()
          
          // Basic structure validation
          let structureValid = 
            try
              let _ = Darklang.Cli2.Commands.System.getEnhancedCommands testState
              let _ = Darklang.Cli2.Commands.Navigation.getEnhancedCommands testState
              let _ = Darklang.Cli2.Commands.Development.getEnhancedCommands testState
              let _ = Darklang.Cli2.UI.Help.renderCategorizedHelp []
              let _ = Darklang.Cli2.Commands.ViewHandlers.executeViewCommand testState ""
              true
            with _ -> false

          if structureValid then
            Builtin.printLine "✅ CLI2 development structure is valid"
            Builtin.printLine "💡 Run full test suite with: @Darklang.Cli2.Tests.TestRunner.runCli2TestSuite"
          else
            Builtin.printLine "❌ CLI2 development structure has issues"
            Builtin.printLine "🔧 Check module imports and function definitions"