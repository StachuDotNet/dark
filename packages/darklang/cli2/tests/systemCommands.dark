module Darklang =
  module Cli2 =
    module Tests =
      module SystemCommands =
        /// Comprehensive tests for CLI2 System Commands
        /// Tests individual commands in isolation to ensure they work correctly

        /// Test result type for individual command tests
        type CommandTestResult =
          { testName: String
            passed: Bool
            message: String
            expectedResult: String
            actualResult: String }

        /// Helper to create test state
        let createTestState (): State =
          State
            { currentPage = Page.Root
              pageHistory = []
              mainPrompt = ""
              cursorPosition = 0L
              commandHistory = []
              interactionMode = InteractionMode.Regular
              commandResult = CommandResult.Info ""
              needsFullRedraw = false }

        /// Test version command
        let testVersionCommand (): CommandTestResult =
          let testState = createTestState ()
          let versionCmd = Darklang.Cli2.Commands.System.versionCommand
          let (newState, msgs) = versionCmd.execute testState ""

          match newState.commandResult with
          | CommandResult.Info versionStr ->
            let passed = Stdlib.String.contains versionStr "Darklang CLI" || Stdlib.String.contains versionStr "alpha"
            CommandTestResult
              { testName = "Version Command"
                passed = passed
                message = if passed then "Version command returned expected format" else "Version command output unexpected"
                expectedResult = "Version string containing 'Darklang CLI' or 'alpha'"
                actualResult = versionStr }
          | _ ->
            CommandTestResult
              { testName = "Version Command"
                passed = false
                message = "Version command did not return Info result"
                expectedResult = "CommandResult.Info with version string"
                actualResult = "Unexpected CommandResult type" }

        /// Test help command basic functionality
        let testHelpCommand (): CommandTestResult =
          let testState = createTestState ()
          let helpCmd = Darklang.Cli2.Commands.System.helpCommand
          let (newState, msgs) = helpCmd.execute testState ""

          match newState.commandResult with
          | CommandResult.Info helpStr ->
            let hasCategories = 
              Stdlib.String.contains helpStr "System Commands" &&
              Stdlib.String.contains helpStr "Navigation Commands" &&
              Stdlib.String.contains helpStr "Development Commands"
            CommandTestResult
              { testName = "Help Command (All Categories)"
                passed = hasCategories
                message = if hasCategories then "Help shows all command categories" else "Help missing expected categories"
                expectedResult = "Help text with System, Navigation, Development categories"
                actualResult = helpStr }
          | _ ->
            CommandTestResult
              { testName = "Help Command (All Categories)"
                passed = false
                message = "Help command did not return Info result"
                expectedResult = "CommandResult.Info with categorized help"
                actualResult = "Unexpected CommandResult type" }

        /// Test help command with system category
        let testHelpSystemCategory (): CommandTestResult =
          let testState = createTestState ()
          let helpCmd = Darklang.Cli2.Commands.System.helpCommand
          let (newState, msgs) = helpCmd.execute testState "system"

          match newState.commandResult with
          | CommandResult.Info helpStr ->
            let hasSystemCommands = 
              Stdlib.String.contains helpStr "System Commands" &&
              Stdlib.String.contains helpStr "help" &&
              Stdlib.String.contains helpStr "version"
            CommandTestResult
              { testName = "Help Command (System Category)"
                passed = hasSystemCommands
                message = if hasSystemCommands then "Help system shows system commands" else "Help system missing expected commands"
                expectedResult = "System category help with help, version commands"
                actualResult = helpStr }
          | _ ->
            CommandTestResult
              { testName = "Help Command (System Category)"
                passed = false
                message = "Help system command did not return Info result"
                expectedResult = "CommandResult.Info with system help"
                actualResult = "Unexpected CommandResult type" }

        /// Test help command with specific command
        let testHelpSpecificCommand (): CommandTestResult =
          let testState = createTestState ()
          let helpCmd = Darklang.Cli2.Commands.System.helpCommand
          let (newState, msgs) = helpCmd.execute testState "version"

          match newState.commandResult with
          | CommandResult.Info helpStr ->
            let hasCommandDetails = 
              Stdlib.String.contains helpStr "version" &&
              Stdlib.String.contains helpStr "examples"
            CommandTestResult
              { testName = "Help Command (Specific Command)"
                passed = hasCommandDetails
                message = if hasCommandDetails then "Help version shows command details" else "Help version missing expected details"
                expectedResult = "Version command help with examples"
                actualResult = helpStr }
          | _ ->
            CommandTestResult
              { testName = "Help Command (Specific Command)"
                passed = false
                message = "Help version command did not return Info result"
                expectedResult = "CommandResult.Info with version command help"
                actualResult = "Unexpected CommandResult type" }

        /// Test status command
        let testStatusCommand (): CommandTestResult =
          let testState = createTestState ()
          let statusCmd = Darklang.Cli2.Commands.System.statusCommand
          let (newState, msgs) = statusCmd.execute testState ""

          match newState.commandResult with
          | CommandResult.Info statusStr ->
            let hasLocationInfo = 
              Stdlib.String.contains statusStr "Current location" &&
              Stdlib.String.contains statusStr "Interaction mode"
            CommandTestResult
              { testName = "Status Command"
                passed = hasLocationInfo
                message = if hasLocationInfo then "Status shows location and mode info" else "Status missing expected information"
                expectedResult = "Status with location and interaction mode"
                actualResult = statusStr }
          | _ ->
            CommandTestResult
              { testName = "Status Command"
                passed = false
                message = "Status command did not return Info result"
                expectedResult = "CommandResult.Info with status information"
                actualResult = "Unexpected CommandResult type" }

        /// Test quit command
        let testQuitCommand (): CommandTestResult =
          let testState = createTestState ()
          let quitCmd = Darklang.Cli2.Commands.System.quitCommand
          let (newState, msgs) = quitCmd.execute testState ""

          let hasQuitMessage = 
            match msgs with
            | [Msg.Quit] -> true
            | _ -> false

          CommandTestResult
            { testName = "Quit Command"
              passed = hasQuitMessage
              message = if hasQuitMessage then "Quit command sends Quit message" else "Quit command missing Quit message"
              expectedResult = "Messages list containing [Msg.Quit]"
              actualResult = $"Messages: {msgs}" }

        /// Test clear command
        let testClearCommand (): CommandTestResult =
          let testState = createTestState ()
          let clearCmd = Darklang.Cli2.Commands.System.clearCommand
          let (newState, msgs) = clearCmd.execute testState ""

          let hasClearMessage = 
            match msgs with
            | [Msg.ClearScreen] -> true
            | _ -> false

          let hasFullRedraw = newState.needsFullRedraw

          CommandTestResult
            { testName = "Clear Command"
              passed = hasClearMessage && hasFullRedraw
              message = if hasClearMessage && hasFullRedraw then "Clear command works correctly" else "Clear command missing expected behavior"
              expectedResult = "ClearScreen message and needsFullRedraw = true"
              actualResult = $"Messages: {msgs}, needsFullRedraw: {hasFullRedraw}" }

        /// Run all system command tests
        let runSystemCommandTests (): List<CommandTestResult> =
          [
            testVersionCommand ()
            testHelpCommand ()
            testHelpSystemCategory ()
            testHelpSpecificCommand ()
            testStatusCommand ()
            testQuitCommand ()
            testClearCommand ()
          ]

        /// Print system command test results
        let printSystemCommandResults (results: List<CommandTestResult>): Unit =
          Builtin.printLine ""
          Builtin.printLine "=== CLI2 System Command Test Results ==="
          
          let passedCount = results |> Stdlib.List.filter (fun r -> r.passed) |> Stdlib.List.length
          let totalCount = Stdlib.List.length results
          
          Builtin.printLine $"Passed: {passedCount}/{totalCount} tests"
          Builtin.printLine ""

          results
          |> Stdlib.List.iter (fun result ->
            let status = if result.passed then "✓ PASS" else "✗ FAIL"
            Builtin.printLine $"{status}: {result.testName}"
            Builtin.printLine $"  {result.message}"
            if Stdlib.Bool.not result.passed then
              Builtin.printLine $"  Expected: {result.expectedResult}"
              Builtin.printLine $"  Actual: {result.actualResult}"
            Builtin.printLine ""
          )