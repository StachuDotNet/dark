module Darklang =
  module Cli2 =
    module Tests =
      module NavigationCommands =
        /// Comprehensive tests for CLI2 Navigation Commands
        /// Tests individual commands and context handlers in isolation

        /// Test back command
        let testBackCommand (): CommandTestResult =
          let testState = createTestState ()
          let backCmd = Darklang.Cli2.Commands.Navigation.backCommand
          let (newState, msgs) = backCmd.execute testState ""

          let hasNavigateBackMessage = 
            match msgs with
            | [Msg.NavigateBack] -> true
            | _ -> false

          CommandTestResult
            { testName = "Back Command"
              passed = hasNavigateBackMessage
              message = if hasNavigateBackMessage then "Back command sends NavigateBack message" else "Back command missing NavigateBack message"
              expectedResult = "Messages list containing [Msg.NavigateBack]"
              actualResult = $"Messages: {msgs}" }

        /// Test ls command in Root context
        let testLsCommandInRoot (): CommandTestResult =
          let testState = createTestState () // Root page by default
          let lsCmd = Darklang.Cli2.Commands.Navigation.lsCommand
          let (newState, msgs) = lsCmd.execute testState ""

          match newState.commandResult with
          | CommandResult.Success listText ->
            let hasExpectedItems = 
              Stdlib.String.contains listText "modules" &&
              Stdlib.String.contains listText "types" &&
              Stdlib.String.contains listText "functions" &&
              Stdlib.String.contains listText "constants"
            CommandTestResult
              { testName = "LS Command (Root Context)"
                passed = hasExpectedItems
                message = if hasExpectedItems then "LS in root shows expected categories" else "LS in root missing expected categories"
                expectedResult = "List with modules, types, functions, constants"
                actualResult = listText }
          | _ ->
            CommandTestResult
              { testName = "LS Command (Root Context)"
                passed = false
                message = "LS command did not return Success result"
                expectedResult = "CommandResult.Success with category list"
                actualResult = "Unexpected CommandResult type" }

        /// Test view command context handlers - viewInRoot
        let testViewInRootHandler (): CommandTestResult =
          let testState = createTestState () // Root page
          let (newState, msgs) = Darklang.Cli2.Commands.ViewHandlers.viewInRoot testState "NonExistentModule"

          // This should either show module contents or try to view an entity
          let hasResult = 
            match newState.commandResult with
            | CommandResult.Success _ -> true
            | CommandResult.Error _ -> true  // Entity not found is expected
            | CommandResult.Info _ -> true
            | _ -> false

          CommandTestResult
            { testName = "View Handler (Root Context)"
              passed = hasResult
              message = if hasResult then "viewInRoot handler executes without crashing" else "viewInRoot handler failed to execute"
              expectedResult = "Some CommandResult (Success, Error, or Info)"
              actualResult = $"CommandResult type: {newState.commandResult}" }

        /// Test view command with empty args
        let testViewCommandEmptyArgs (): CommandTestResult =
          let testState = createTestState ()
          let (newState, msgs) = Darklang.Cli2.Commands.ViewHandlers.executeViewCommand testState ""

          match newState.commandResult with
          | CommandResult.Info infoText ->
            let hasHelpMessage = Stdlib.String.contains infoText "Please specify an entity name"
            CommandTestResult
              { testName = "View Command (Empty Args)"
                passed = hasHelpMessage
                message = if hasHelpMessage then "View with empty args shows help message" else "View with empty args missing help message"
                expectedResult = "Info message asking to specify entity name"
                actualResult = infoText }
          | _ ->
            CommandTestResult
              { testName = "View Command (Empty Args)"
                passed = false
                message = "View with empty args did not return Info result"
                expectedResult = "CommandResult.Info with help message"
                actualResult = "Unexpected CommandResult type" }

        /// Test view command with Module context
        let testViewInModuleHandler (): CommandTestResult =
          // Create a test state with Module context
          let moduleState = 
            { (createTestState ()) with currentPage = Page.Module("Darklang", ["Stdlib"]) }
          
          let (newState, msgs) = Darklang.Cli2.Commands.ViewHandlers.viewInModule moduleState "Darklang" ["Stdlib"] "String"

          let hasResult = 
            match newState.commandResult with
            | CommandResult.Success _ -> true
            | CommandResult.Error _ -> true  // Entity not found is expected for non-existent entities
            | CommandResult.Info _ -> true
            | _ -> false

          CommandTestResult
            { testName = "View Handler (Module Context)"
              passed = hasResult
              message = if hasResult then "viewInModule handler executes without crashing" else "viewInModule handler failed to execute"
              expectedResult = "Some CommandResult (Success, Error, or Info)"
              actualResult = $"CommandResult type: {newState.commandResult}" }

        /// Test cd command basic execution
        let testCdCommand (): CommandTestResult =
          let testState = createTestState ()
          let cdCmd = Darklang.Cli2.Commands.Navigation.cdCommand
          
          // Test cd with a basic path - this should delegate to existing navigation logic
          let (newState, msgs) = cdCmd.execute testState "Darklang"

          // Since this delegates to existing logic, we just check it doesn't crash
          CommandTestResult
            { testName = "CD Command (Basic)"
              passed = true  // If we get here without crashing, it passed
              message = "CD command executes without crashing"
              expectedResult = "Command executes successfully"
              actualResult = "Command completed execution" }

        /// Test enhanced command details structure
        let testEnhancedCommandStructure (): CommandTestResult =
          let testState = createTestState ()
          let navCommands = Darklang.Cli2.Commands.Navigation.getEnhancedCommands testState

          let allCommandsHaveCategories = 
            navCommands
            |> Stdlib.List.forall (fun cmd -> 
                match cmd.category with
                | CommandCategory.Navigation -> true
                | _ -> false)

          let allCommandsHaveExamples = 
            navCommands
            |> Stdlib.List.forall (fun cmd -> Stdlib.Bool.not (Stdlib.List.isEmpty cmd.examples))

          let structureValid = allCommandsHaveCategories && allCommandsHaveExamples

          CommandTestResult
            { testName = "Enhanced Command Structure"
              passed = structureValid
              message = if structureValid then "All navigation commands have proper categories and examples" else "Some navigation commands missing categories or examples"
              expectedResult = "All commands with Navigation category and non-empty examples"
              actualResult = $"Categories valid: {allCommandsHaveCategories}, Examples valid: {allCommandsHaveExamples}" }

        /// Run all navigation command tests
        let runNavigationCommandTests (): List<CommandTestResult> =
          [
            testBackCommand ()
            testLsCommandInRoot ()
            testViewInRootHandler ()
            testViewCommandEmptyArgs ()
            testViewInModuleHandler ()
            testCdCommand ()
            testEnhancedCommandStructure ()
          ]

        /// Print navigation command test results
        let printNavigationCommandResults (results: List<CommandTestResult>): Unit =
          Builtin.printLine ""
          Builtin.printLine "=== CLI2 Navigation Command Test Results ==="
          
          let passedCount = results |> Stdlib.List.filter (fun r -> r.passed) |> Stdlib.List.length
          let totalCount = Stdlib.List.length results
          
          Builtin.printLine $"Passed: {passedCount}/{totalCount} tests"
          Builtin.printLine ""

          results
          |> Stdlib.List.iter (fun result ->
            let status = if result.passed then "✓ PASS" else "✗ FAIL"
            Builtin.printLine $"{status}: {result.testName}"
            Builtin.printLine $"  {result.message}"
            if Stdlib.Bool.not result.passed then
              Builtin.printLine $"  Expected: {result.expectedResult}"
              Builtin.printLine $"  Actual: {result.actualResult}"
            Builtin.printLine ""
          )