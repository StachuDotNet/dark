module IndexOf =
  Stdlib.String.indexOf "hello world" "world" = Stdlib.Option.Option.Some 6
  Stdlib.String.indexOf "hello world" "earth" = Stdlib.Option.Option.None
  Stdlib.String.indexOf "" "" = Stdlib.Option.Option.Some 0
  Stdlib.String.indexOf "hello" "" = Stdlib.Option.Option.Some 0
  Stdlib.String.indexOf "" "hello" = Stdlib.Option.Option.None
  Stdlib.String.indexOf "👱👱🏻👱🏼👱🏽👱🏾👱🏿" "👱🏼👱🏽" = Stdlib.Option.Option.Some 6
  Stdlib.String.indexOf "👱👱🏻👱🏼👱🏽👱🏾👱🏿" "👱🏼👱🏿" = Stdlib.Option.Option.None
  Stdlib.String.indexOf "👨‍❤️‍💋‍👨👩‍👩‍👧‍👦🏳️‍⚧️‍️🇵🇷" "👩‍👩‍👧‍👦" = Stdlib.Option.Option.Some 11
  Stdlib.String.indexOf "żółw🧑🏽‍🦰🧑🏻‍🍼✋✋🏻✋🏿" "🧑🏽‍🦰" = Stdlib.Option.Option.Some 4
  Stdlib.String.indexOf "żółw🧑🏽‍🦰🧑🏻‍🍼✋✋🏻✋🏿" "👱🏽" = Stdlib.Option.Option.None
  Stdlib.String.indexOf "👨‍❤️‍💋‍👨👩‍👩‍👧‍👦🏳️‍⚧️‍️🇵🇷" "🧑🏻‍🍼" = Stdlib.Option.Option.None


module IndexOfEgc =
  // Mirror of the IndexOf module above, but in EGC units. Pair with first /
  // dropFirst / slice / length for correct emoji-safe slicing.
  Stdlib.String.indexOfEgc "hello world" "world" = Stdlib.Option.Option.Some 6
  Stdlib.String.indexOfEgc "hello world" "earth" = Stdlib.Option.Option.None
  Stdlib.String.indexOfEgc "" "" = Stdlib.Option.Option.Some 0
  Stdlib.String.indexOfEgc "hello" "" = Stdlib.Option.Option.Some 0
  Stdlib.String.indexOfEgc "" "hello" = Stdlib.Option.Option.None

  // "👱👱🏻" is 2 EGCs, "👨‍❤️‍💋‍👨" is 1 EGC, "żółw" is 4 EGCs.
  Stdlib.String.indexOfEgc "👱👱🏻👱🏼👱🏽👱🏾👱🏿" "👱🏼👱🏽" = Stdlib.Option.Option.Some 2
  Stdlib.String.indexOfEgc "👱👱🏻👱🏼👱🏽👱🏾👱🏿" "👱🏼👱🏿" = Stdlib.Option.Option.None
  Stdlib.String.indexOfEgc "👨‍❤️‍💋‍👨👩‍👩‍👧‍👦🏳️‍⚧️‍️🇵🇷" "👩‍👩‍👧‍👦" = Stdlib.Option.Option.Some 1
  Stdlib.String.indexOfEgc "żółw🧑🏽‍🦰🧑🏻‍🍼✋✋🏻✋🏿" "🧑🏽‍🦰" = Stdlib.Option.Option.Some 4

  // Matches must align to EGC boundaries on both sides. Searching for a partial
  // grapheme inside a full one returns None: 🧑 is not a complete EGC of 🧑🏼‍💻.
  Stdlib.String.indexOfEgc "🧑🏼‍💻" "🧑" = Stdlib.Option.Option.None
  // Standalone 🧑 at EGC index 0 is matchable when it stands on its own.
  Stdlib.String.indexOfEgc "🧑🧑🏼‍💻" "🧑" = Stdlib.Option.Option.Some 0


module LastIndexOfEgc =
  // Basic ASCII: last occurrence wins.
  Stdlib.String.lastIndexOfEgc "hello world hello" "hello" = Stdlib.Option.Option.Some 12
  Stdlib.String.lastIndexOfEgc "hello world" "earth" = Stdlib.Option.Option.None
  Stdlib.String.lastIndexOfEgc "" "hello" = Stdlib.Option.Option.None

  // Empty-string searches return string length in EGCs.
  Stdlib.String.lastIndexOfEgc "" "" = Stdlib.Option.Option.Some 0
  Stdlib.String.lastIndexOfEgc "hello" "" = Stdlib.Option.Option.Some 5
  // "👱👱🏻" is 2 EGCs even though it's 4 UTF-16 code units.
  Stdlib.String.lastIndexOfEgc "👱👱🏻" "" = Stdlib.Option.Option.Some 2

  // EGC offsets across multi-codepoint graphemes.
  Stdlib.String.lastIndexOfEgc "👱👱🏻👱🏼👱🏽👱🏾👱🏿" "👱🏼" = Stdlib.Option.Option.Some 2
  Stdlib.String.lastIndexOfEgc "a🧑🏼‍💻b🧑🏼‍💻c" "🧑🏼‍💻" = Stdlib.Option.Option.Some 3
  Stdlib.String.lastIndexOfEgc "żółw🧑🏽‍🦰🧑🏻‍🍼" "🧑🏻‍🍼" = Stdlib.Option.Option.Some 5

  // Partial-grapheme search returns None on both sides (start and end must
  // align to EGC boundaries).
  Stdlib.String.lastIndexOfEgc "🧑🏼‍💻🧑🏼‍💻" "🧑" = Stdlib.Option.Option.None
  // Standalone 🧑 at the end is matchable when it stands on its own.
  Stdlib.String.lastIndexOfEgc "🧑🏼‍💻🧑" "🧑" = Stdlib.Option.Option.Some 1


module Ellipsis =
  Stdlib.String.ellipsis "hello world" 5 = "hello..."
  Stdlib.String.ellipsis "hello world" 9 = "hello wor..."
  Stdlib.String.ellipsis "hello world" 11 = "hello world"
  Stdlib.String.ellipsis "hello world" 12 = "hello world"
  Stdlib.String.ellipsis "👱👱🏻👱🏼👱🏽👱🏾👱🏿" 5 = "👱👱🏻👱🏼👱🏽👱🏾..."
  Stdlib.String.ellipsis "Z̤͔ͧ̑̓ä͖̭̈̇lͮ̒ͫǧ̗͚̚o̙̔ͮ̇͐̇" 3 = "Z̤͔ͧ̑̓ä͖̭̈̇lͮ̒ͫ..."
  Stdlib.String.ellipsis "👩‍👩‍👧‍👦" 2 = "👩‍👩‍👧‍👦"

  Stdlib.String.ellipsis "👨‍❤️‍💋‍👨👩‍👩‍👧‍👦🏳️‍⚧️‍️🇵🇷✋✋🏻✋🏿" 4 = "👨‍❤️‍💋‍👨👩‍👩‍👧‍👦🏳️‍⚧️‍️🇵🇷..."

module Head =
  Stdlib.String.head "hello world" = Stdlib.Option.Option.Some 'h'

  Stdlib.String.head "" = Stdlib.Option.Option.None

  // Commented out as F# parser doesn't like unicode "characters"
  // CLEANUP uncomment when switched to new parser
  // Stdlib.String.head "👱👱🏻👱🏼👱🏽👱🏾👱🏿" = Stdlib.Option.Option.Some '👱'
  // Stdlib.String.head "🧟‍♀️🧟‍♂️" = Stdlib.Option.Option.Some '🧟'
  // Stdlib.String.head "👨‍❤️‍💋‍👨" = Stdlib.Option.Option.Some '👨‍❤️‍💋‍👨'

module ArticleFor =
  Stdlib.String.articleFor "apple" = "an"
  Stdlib.String.articleFor "banana" = "a"
  Stdlib.String.articleFor "🍍" = "a"
  Stdlib.String.articleFor "🍊" = "a"
  Stdlib.String.articleFor "" = ""