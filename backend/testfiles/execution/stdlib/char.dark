// Valid codepoints
Stdlib.Char.fromCodepoint 65 = Stdlib.Option.Option.Some 'A'
Stdlib.Char.fromCodepoint 233 = Stdlib.Option.Option.Some 'é'
// Non-BMP: pins the surrogate-pair path through ConvertFromUtf32. 0x1F602 = 😂
Stdlib.Char.fromCodepoint 128514 = Stdlib.Option.Option.Some (smiley ())

// Invalid: surrogate range (D800..DFFF) — reserved for UTF-16 surrogate pairs
Stdlib.Char.fromCodepoint 55296 = Stdlib.Option.Option.None
Stdlib.Char.fromCodepoint 56319 = Stdlib.Option.Option.None
Stdlib.Char.fromCodepoint 57343 = Stdlib.Option.Option.None

// Invalid: above Unicode max (0x10FFFF)
Stdlib.Char.fromCodepoint 1114112 = Stdlib.Option.Option.None
Stdlib.Char.fromCodepoint 2147483647 = Stdlib.Option.Option.None

// Invalid: negative — the F# test parser rejects `-NL`, so build via `0L - N`.
Stdlib.Char.fromCodepoint (0 - 1) = Stdlib.Option.Option.None
Stdlib.Char.fromCodepoint (0 - 1000) = Stdlib.Option.Option.None