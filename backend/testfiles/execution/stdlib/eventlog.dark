// The native op-log read API (`Stdlib.EventLog`) that sync reads from. Reading past the end of the log
// leaves the cursor unchanged ‚Äî the "already current" shape a peer serves a caught-up puller. The full
// readSince‚Üíappend‚Üíconverge path (origin_ts preservation + fold) is covered in the F# suite
// (OpsProjections.Tests); this pins the Dark-side read contract.

module EventLog =
  ((Stdlib.EventLog.readSince
     (Stdlib.EventLog.cursorFromInt 999999999L)
     500L)
   |> (fun b -> Stdlib.EventLog.cursorToInt b.next)) = 999999999L
