// Arbitrary-precision `Int` — the small/big representation split.
//
// `Int` is stored as a small (Int64-backed) value when it fits, and only
// promotes to a big representation on overflow. Values are NORMALIZED: any
// result that fits Int64 always uses the small representation. These tests
// exercise the boundary, promotion, demotion, normalization, and finite/infinite
// ordering — the properties that break if normalization is wrong. Literals use
// the F# `I` suffix because these testfiles are parsed by the F# parser.

// --- boundary: largest small value vs first big value ---
9223372036854775807 + 0 = 9223372036854775807 // Int64.MAX stays small
9223372036854775807 + 1 = 9223372036854775808 // promotes past Int64.MAX
-9223372036854775808 - 1 = -9223372036854775809 // promotes past Int64.MIN

// --- demotion: a big-arithmetic result that fits Int64 collapses to small ---
9223372036854775808 - 1 = 9223372036854775807
(2 ^ 100) - (2 ^ 100) = 0
(2 ^ 100) / (2 ^ 100) = 1

// --- normalization: a promoted-then-demoted result equals the small literal ---
// (this is the property that fails if a small value is left as the big rep)
(9223372036854775808 - 9223372036854775808) == 0 = true
9223372036854775807 == (9223372036854775806 + 1) = true

// --- equality and ordering across representations ---
(2 ^ 64) == (2 ^ 64) = true
9223372036854775808 > 5 = true
5 < 9223372036854775808 = true
9223372036854775808 == 5 = false

// --- arithmetic correctness at scale ---
2 ^ 64 = 18446744073709551616
2 ^ 200
  = 1606938044258990275541962092341162602522202993782792835301376

// --- round-trips (stringify / parse / Int64 conversions) ---
Stdlib.Int.toString 5 = "5"
Stdlib.Int.toString 9223372036854775808 = "9223372036854775808"
Stdlib.Int.parse "9223372036854775808" = Stdlib.Result.Result.Ok 9223372036854775808
Stdlib.Int.parse "5" = Stdlib.Result.Result.Ok 5
Stdlib.Int.parse "not a number" = Stdlib.Result.Result.Error Stdlib.Int.ParseError.BadFormat
Stdlib.Int.parse "" = Stdlib.Result.Result.Error Stdlib.Int.ParseError.BadFormat
Stdlib.Int.parse "5.0" = Stdlib.Result.Result.Error Stdlib.Int.ParseError.BadFormat
Stdlib.Int.parse "5_000" = Stdlib.Result.Result.Error Stdlib.Int.ParseError.BadFormat
// arbitrary precision: a value past Int64.MinValue still parses
Stdlib.Int.parse "-9223372036854775809" = Stdlib.Result.Result.Ok -9223372036854775809
Stdlib.Int.fromInt64 5L = 5

// toInt64 relies on the invariant: a small Int always fits, a big Int never does
Stdlib.Int.toInt64 5 = Stdlib.Option.Option.Some 5L
Stdlib.Int.toInt64 9223372036854775808 = Stdlib.Option.Option.None


// --- conversions from the fixed-width types (always succeed) ---
Stdlib.Int.fromInt8 127y = 127
Stdlib.Int.fromUInt8 255uy = 255
Stdlib.Int.fromInt16 32767s = 32767
Stdlib.Int.fromUInt32 4294967295ul = 4294967295
// values past Int64 still convert exactly
Stdlib.Int.fromUInt64 18446744073709551615UL = 18446744073709551615
Stdlib.Int.fromUInt128 340282366920938463463374607431768211455Z =
  340282366920938463463374607431768211455

// --- conversions into the fixed-width types (Some if it fits, else None) ---
Stdlib.Int.toInt8 100 = Stdlib.Option.Option.Some 100y
Stdlib.Int.toInt8 200 = Stdlib.Option.Option.None
Stdlib.Int.toUInt8 (Stdlib.Int.negate 1) = Stdlib.Option.Option.None
Stdlib.Int.toInt32 (2 ^ 40) = Stdlib.Option.Option.None
Stdlib.Int.toInt128 (2 ^ 100) =
  Stdlib.Option.Option.Some 1267650600228229401496703205376Q
Stdlib.Int.toInt128 (2 ^ 200) = Stdlib.Option.Option.None
Stdlib.Int.toUInt128 (2 ^ 200) = Stdlib.Option.Option.None

// --- fromFloat: truncates toward zero; NaN/Infinity have no Int, so OutOfRange ---
Stdlib.Int.fromFloat 3.9 = 3
Stdlib.Int.fromFloat -3.9 = -3
Stdlib.Int.fromFloat (0.0 / 0.0) =
  error="Encountered out-of-range value for type of Int"
Stdlib.Int.fromFloat (1.0 / 0.0) =
  error="Encountered out-of-range value for type of Int"
Stdlib.Int.fromFloat (-1.0 / 0.0) =
  error="Encountered out-of-range value for type of Int"


// --- remainder: Result<Int>; sign follows the dividend; Error only if divisor is 0 ---
Stdlib.Int.remainder 15 6 = Stdlib.Result.Result.Ok 3
Stdlib.Int.remainder 20 8 = Stdlib.Result.Result.Ok 4
Stdlib.Int.remainder -20 8 = Stdlib.Result.Result.Ok -4
Stdlib.Int.remainder -20 -8 = Stdlib.Result.Result.Ok -4
Stdlib.Int.remainder -15 6 = Stdlib.Result.Result.Ok -3
Stdlib.Int.remainder 5 0 = Stdlib.Result.Result.Error "Cannot divide by 0"
// arbitrary precision: 2^100 mod 7 == 2, with a dividend well past Int64
Stdlib.Int.remainder (2 ^ 100) 7 = Stdlib.Result.Result.Ok 2

// --- mod: wraps into [0, b); RTE if b <= 0 ---
Stdlib.Int.mod 15 5 = 0
Stdlib.Int.mod 15 6 = 3
Stdlib.Int.mod 0 15 = 0
Stdlib.Int.mod -1 2 = 1
Stdlib.Int.mod -754 53 = 41
Stdlib.Int.mod (2 ^ 100) 7 = 2
Stdlib.Int.mod 5 0 = error="Cannot evaluate modulus against 0"
Stdlib.Int.mod 5 -5 = error="Cannot evaluate modulus against a negative number"

// the % operator dispatches to mod
15 % 5 = 0
5 % 0 = error="Cannot evaluate modulus against 0"
5 % -5 = error="Cannot evaluate modulus against a negative number"

// --- shiftLeft / shiftRight: count must fit Int32, else OutOfRange ---
Stdlib.Int.shiftLeft 1 4 = 16
Stdlib.Int.shiftLeft 1 64 = 18446744073709551616
Stdlib.Int.shiftRight 256 4 = 16
Stdlib.Int.shiftLeft 1 (2 ^ 40) =
  error="Encountered out-of-range value for type of Int"
Stdlib.Int.shiftRight 1 (2 ^ 40) =
  error="Encountered out-of-range value for type of Int"
