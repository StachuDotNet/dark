// TODO: Add additional tests to cover all cases
type TokenType = Darklang.LanguageTools.SemanticTokens.TokenType

let tokenize
  (text: String)
  : List<(Darklang.LanguageTools.SemanticTokens.TokenType * (Int * Int) * (Int * Int))>
  =
  text
  |> Builtin.parserParseToWrittenTypes
  |> Builtin.unwrap
  |> Darklang.LanguageTools.SemanticTokens.ParsedFile.tokenize
  |> Stdlib.List.map (fun token ->
    let rangeStart = (token.range.start.row, token.range.start.column)
    let rangeEnd = (token.range.end_.row, token.range.end_.column)
    (token.tokenType, rangeStart, rangeEnd))


