module TokenizeExpression =
  ("()" |> tokenize) = [ (TokenType.Symbol, (0, 0), (0, 2)) ]
  ("true" |> tokenize) = [ (TokenType.Keyword, (0, 0), (0, 4)) ]

  ("1y" |> tokenize) = [ (TokenType.Number, (0, 0), (0, 2))
                         (TokenType.Symbol, (0, 2), (0, 2)) ]

  ("1uy" |> tokenize) = [ (TokenType.Number, (0, 0), (0, 3))
                          (TokenType.Symbol, (0, 3), (0, 3)) ]

  ("1s" |> tokenize) = [ (TokenType.Number, (0, 0), (0, 2))
                         (TokenType.Symbol, (0, 2), (0, 2)) ]

  ("1us" |> tokenize) = [ (TokenType.Number, (0, 0), (0, 3))
                          (TokenType.Symbol, (0, 3), (0, 3)) ]

  ("1l" |> tokenize) = [ (TokenType.Number, (0, 0), (0, 2))
                         (TokenType.Symbol, (0, 2), (0, 2)) ]

  ("1ul" |> tokenize) = [ (TokenType.Number, (0, 0), (0, 3))
                          (TokenType.Symbol, (0, 3), (0, 3)) ]

  ("1L" |> tokenize) = [ (TokenType.Number, (0, 0), (0, 2))
                         (TokenType.Symbol, (0, 2), (0, 2)) ]

  ("1UL" |> tokenize) = [ (TokenType.Number, (0, 0), (0, 3))
                          (TokenType.Symbol, (0, 3), (0, 3)) ]

  ("1Q" |> tokenize) = [ (TokenType.Number, (0, 0), (0, 2))
                         (TokenType.Symbol, (0, 2), (0, 2)) ]

  ("1Z" |> tokenize) = [ (TokenType.Number, (0, 0), (0, 2))
                         (TokenType.Symbol, (0, 2), (0, 2)) ]

  // suffixless Int literal: just a Number token, no suffix Symbol
  ("1" |> tokenize) = [ (TokenType.Number, (0, 0), (0, 1)) ]

  ("12345678901234567890" |> tokenize) =
    [ (TokenType.Number, (0, 0), (0, 20)) ]

  ("1.0" |> tokenize) = [ (TokenType.Number, (0, 0), (0, 3)) ]

  ("\"hello\"" |> tokenize) =
    [ (TokenType.Symbol, (0, 0), (0, 0))
      (TokenType.String, (0, 0), (0, 7))
      (TokenType.Symbol, (0, 7), (0, 7)) ]

  ("$\"hello {name}\"" |> tokenize) =
    [ (TokenType.Symbol, (0, 0), (0, 1))
      (TokenType.Symbol, (0, 1), (0, 2))
      (TokenType.String, (0, 2), (0, 8))
      (TokenType.Symbol, (0, 8), (0, 9))
      (TokenType.VariableName, (0, 9), (0, 13))
      (TokenType.Symbol, (0, 13), (0, 14))
      (TokenType.Symbol, (0, 14), (0, 15)) ]

  ("$\"Name: {name}, Age: {age}\"" |> tokenize) =
    [ (TokenType.Symbol, (0, 0), (0, 1))
      (TokenType.Symbol, (0, 1), (0, 2))
      (TokenType.String, (0, 2), (0, 8))
      (TokenType.Symbol, (0, 8), (0, 9))
      (TokenType.VariableName, (0, 9), (0, 13))
      (TokenType.Symbol, (0, 13), (0, 14))
