$"""test {"1"}""" = "test 1"

(let one = "1" in $"test {one}") = "test 1"

(let one = 1.0 in $"test {one}") = error="Expected String in string interpolation, got a Float (1.0) instead. Try wrapping it with `Stdlib.Float.toString`."
(let one = 1L in $"test {one}") = error="Expected String in string interpolation, got an Int64 (1) instead. Try wrapping it with `Stdlib.Int64.toString`."
(let name = "John"
 let age = "30"
 $"Name: {name}, Age: {age} years old.") = "Name: John, Age: 30 years old."

(let two = 2L in "test 1" == $"test {one}") = error="There is no variable named: one"
(let one = 1L in $"test {Stdlib.Int64.toString one}") = "test 1"

// --- interpolation scanner and brace escapes ---

// A brace inside a char literal in an interpolation should not end the interpolation.
($"{Stdlib.String.fromChar '}'}") = "}"
($"x{Stdlib.String.append "a" "}"}y") = "xa}y"

// An escaped-quote char literal should not affect later brace scanning.
($"{Stdlib.String.append (Stdlib.String.fromChar '\'') (Stdlib.String.fromChar '}')}") = "'}"

// `\{` and `\}` are literal-brace escapes; `\{\{` yields `{{`.
"\{\}" = "{}"
($"\{\{") = "{{"

// `{{` and `}}` are interpolation escapes for literal braces.
($"a{{b}}c") = "a{b}c"
