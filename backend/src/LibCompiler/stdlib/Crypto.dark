// Debug: trace round 48 (first I function round)
// Returns (f, g, m, k, s, temp, rotated, newB)
def Stdlib.Crypto.debugMd5Round48Trace(padded: Bytes) : (Int64, Int64, Int64, Int64, Int64, Int64, Int64, Int64) =
    // State after 48 rounds: (1062596093, 3397201341, 1759006370, 581115732)
    let a = 1062596093 in
    let b = 3397201341 in
    let c = 1759006370 in
    let d = 581115732 in
    let i = 48 in
    let f = Stdlib.Crypto.__md5F(i, b, c, d) in
    let g = Stdlib.Crypto.__md5G(i) in
    let m = Stdlib.Crypto.__md5GetWord(padded, 0, g) in
    let k = Stdlib.Crypto.__md5K(i) in
    let s = Stdlib.Crypto.__md5Shift(i) in
    let temp = Stdlib.Crypto.__add32(Stdlib.Crypto.__add32(Stdlib.Crypto.__add32(a, f), k), m) in
    let rotated = Stdlib.Crypto.__rotl32(temp, s) in
    let newB = Stdlib.Crypto.__add32(b, rotated) in
    (f, g, m, k, s, temp, rotated, newB)

// Debug: test I function components
// I(b, c, d) = c ^ (b | ~d)
def Stdlib.Crypto.debugMd5I(b: Int64, c: Int64, d: Int64) : (Int64, Int64, Int64, Int64) =
    let not_d = Stdlib.Crypto.__not32(d) in
    let b_or_not_d = Stdlib.Int64.bitwiseOr(b, not_d) in
    let result = (c ^ b_or_not_d) & Stdlib.Crypto.__mask32() in
    (not_d, b_or_not_d, c, result)

