// Debug: show K values for rounds 48-51
def Stdlib.Crypto.debugMd5K48to51() : (Int64, Int64, Int64, Int64) =
    (Stdlib.Crypto.__md5K(48), Stdlib.Crypto.__md5K(49), Stdlib.Crypto.__md5K(50), Stdlib.Crypto.__md5K(51))

